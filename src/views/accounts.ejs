<%- include('partials/header', { user: currentUser }) %>

<div class="page-head">
  <p class="eyebrow">System Administration</p>
  <h1>Quản lý tài khoản</h1>
  <p class="lede">Thêm, sửa, xóa và phân quyền người dùng.</p>
</div>

<% if (success) { %>
  <div class="alert alert-success">
    <span class="alert-icon">✓</span> <%= success %>
  </div>
<% } %>
<% if (error) { %>
  <div class="alert alert-error">
    <span class="alert-icon">✕</span> <%= error %>
  </div>
<% } %>

<!-- Form thêm tài khoản -->
<div class="card" style="margin-bottom: 40px;">
  <div class="card-header">
    <h2 class="card-title" style="font-size: 1.1rem; margin: 0;">
      <i class="ti ti-user-plus" style="margin-right: 8px;"></i>
      Thêm tài khoản
    </h2>
  </div>
  <div class="card-body">
    <form method="POST" action="/accounts/create" class="form-grid">
      <div class="form-group">
        <label for="username">Tên đăng nhập <span class="required">*</span></label>
        <input type="text" id="username" name="username" placeholder="ví dụ: admin" required />
      </div>
      
      <div class="form-group">
        <label for="fullName">Họ và tên <span class="required">*</span></label>
        <input type="text" id="fullName" name="fullName" placeholder="ví dụ: Nguyễn Văn A" required />
      </div>
      
      <div class="form-group">
        <label for="email">Email <span class="required">*</span></label>
        <input type="email" id="email" name="email" placeholder="example@domain.com" required />
      </div>
      
      <div class="form-group">
        <label for="password">Mật khẩu <span class="required">*</span></label>
        <input type="password" id="password" name="password" placeholder="Nhập mật khẩu" required />
      </div>
      
      <div class="form-group">
        <label for="role">Vai trò <span class="required">*</span></label>
        <select id="role" name="role" required>
          <option value="member">Hội viên</option>
          <option value="staff">Nhân viên</option>
          <option value="trainer">Huấn luyện viên</option>
          <option value="admin">Quản trị viên</option>
        </select>
      </div>
      
      <div class="form-group" style="display: flex; align-items: flex-end;">
        <button type="submit" class="btn btn-primary" style="width: 100%;">
          <i class="ti ti-plus"></i> Thêm tài khoản
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Danh sách tài khoản -->
<div class="card">
  <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
    <h2 class="card-title" style="font-size: 1.1rem; margin: 0;">
      <i class="ti ti-users" style="margin-right: 8px;"></i>
      Danh sách tài khoản
    </h2>
    <span class="badge"><%= accounts ? accounts.length : 0 %> người dùng</span>
  </div>
  <div class="card-body" style="overflow-x: auto;">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Username</th>
          <th>Họ tên</th>
          <th>Email</th>
          <th>Vai trò</th>
          <th style="text-align: center;">Thao tác</th>
        </tr>
      </thead>
      <tbody>
        <% if (accounts && accounts.length > 0) { %>
          <% accounts.forEach(function(acc) { %>
            <tr>
              <td><code style="background: #f0f0f0; padding: 2px 8px; border-radius: 4px; font-size: 0.85rem;"><%= acc.id %></code></td>
              <td><strong><%= acc.username %></strong></td>
              <td><%= acc.fullName %></td>
              <td><a href="mailto:<%= acc.email %>" style="color: var(--color-moss);"><%= acc.email %></a></td>
              <td>
                <span class="role-badge role-<%= acc.role %>">
                  <%= acc.role === 'admin'   ? '👑 Admin'   :
                     acc.role === 'staff'   ? '💼 Staff'   :
                     acc.role === 'trainer' ? '🏋️ Trainer' :
                     '🧘 Member' %>
                </span>
              </td>
              <td style="text-align: center;">
                <div class="action-buttons">
                  <a href="/accounts/<%= acc.id %>/edit" class="btn-icon" title="Sửa">
                    <i class="ti ti-edit"></i>
                  </a>
                  <form method="POST" action="/accounts/<%= acc.id %>/delete" style="display:inline"
                        onsubmit="return confirm('Bạn có chắc chắn muốn xóa tài khoản này?')">
                    <button type="submit" class="btn-icon btn-danger" title="Xóa">
                      <i class="ti ti-trash"></i>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr>
            <td colspan="6" style="text-align: center; padding: 40px 0; color: var(--color-ink-soft);">
              <i class="ti ti-users" style="font-size: 2rem; display: block; margin-bottom: 8px;"></i>
              Chưa có tài khoản nào.
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>


<%- include('partials/footer') %>