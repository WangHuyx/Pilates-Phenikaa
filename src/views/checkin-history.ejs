<%- include('partials/header') %>

<div class="page-head">
  <div>
    <p class="eyebrow">Check-in</p>
    <h1 class="page-title">Lịch sử điểm danh</h1>
    <p class="lede">Tra cứu log ra vào phòng tập</p>
  </div>
  <a href="/checkin" class="btn btn-secondary"><i class="ti ti-arrow-left"></i> Quay lại</a>
</div>

<!-- Toolbar -->
<form method="GET" action="/checkin/history" class="history-toolbar">
  <div class="finance-search-wrap" style="flex:1;min-width:240px;">
    <i class="ti ti-search"></i>
    <input type="text" name="q" value="<%= filterSearch %>" placeholder="Tìm theo tên, mã hội viên..." />
  </div>
  <div style="display:flex;align-items:center;gap:6px;flex-shrink:0;">
    <input type="date" name="dateFrom" value="<%= filterDateFrom %>" class="finance-month" />
    <span style="color:var(--color-ink-soft);font-weight:500;">—</span>
    <input type="date" name="dateTo" value="<%= filterDateTo %>" class="finance-month" />
  </div>
  <button class="btn btn-primary btn-sm" type="submit"><i class="ti ti-filter"></i> Lọc</button>
  <% if (filterSearch || filterDateFrom || filterDateTo) { %>
    <a href="/checkin/history" class="btn btn-secondary btn-sm"><i class="ti ti-x"></i> Xóa lọc</a>
  <% } %>
  <a href="/checkin/history/export?q=<%= encodeURIComponent(filterSearch) %>&dateFrom=<%= filterDateFrom %>&dateTo=<%= filterDateTo %>"
     class="btn btn-secondary btn-sm" style="margin-left:auto;">
    <i class="ti ti-download"></i> Xuất Excel
  </a>
</form>

<!-- Bảng lịch sử -->
<div class="card" style="margin-top:16px;">
  <div style="overflow-x:auto;">
    <table class="table history-table">
      <thead>
        <tr>
          <th>Hội viên</th>
          <th>Mã HV</th>
          <th>Ngày</th>
          <th>Giờ vào</th>
          <th>Giờ ra</th>
          <th>Thời gian tập</th>
        </tr>
      </thead>
      <tbody>
        <% if (checkins.length === 0) { %>
          <tr>
            <td colspan="6" style="text-align:center;padding:48px;color:var(--color-ink-soft);">
              <i class="ti ti-calendar-off" style="font-size:2.5rem;opacity:.3;display:block;margin-bottom:8px;"></i>
              Không có dữ liệu check-in
            </td>
          </tr>
        <% } %>
        <% checkins.forEach(function(c) {
          const uid = c.uid || c.user_id;
          const memberCode = 'HV' + String(uid).padStart(3, '0');
          const letter = (c.full_name || '?').trim().split(' ').pop()[0].toUpperCase();
          const avatarColors = ['#7C3AED','#2563EB','#0891B2','#D97706','#059669','#DC2626','#DB2777','#4F46E5'];
          const avatarBg = avatarColors[uid % avatarColors.length];
          const codeColors = ['#EDE9FE','#DBEAFE','#CFFAFE','#FEF3C7','#D1FAE5','#FEE2E2','#FCE7F3','#E0E7FF'];
          const codeTextColors = ['#6D28D9','#1D4ED8','#0E7490','#92400E','#065F46','#991B1B','#9D174D','#3730A3'];
          const ci = uid % avatarColors.length;
        %>
        <tr>
          <td>
            <div style="display:flex;align-items:center;gap:12px;">
              <div style="width:38px;height:38px;border-radius:50%;background:<%= avatarBg %>;color:#fff;font-weight:700;font-size:0.95rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <%= letter %>
              </div>
              <span style="font-weight:600;"><%= c.full_name %></span>
            </div>
          </td>
          <td>
            <span style="font-family:var(--font-mono,monospace);font-size:0.82rem;font-weight:600;padding:3px 10px;border-radius:999px;background:<%= codeColors[ci] %>;color:<%= codeTextColors[ci] %>;">
              <%= memberCode %>
            </span>
          </td>
          <td style="color:var(--color-ink-soft);">
            <%= new Date(c.check_in_time).toLocaleDateString('vi-VN') %>
          </td>
          <td style="font-weight:500;">
            <%= new Date(c.check_in_time).toLocaleTimeString('vi-VN',{hour:'2-digit',minute:'2-digit'}) %>
          </td>
          <td>
            <% if (c.check_out_time) { %>
              <span style="font-weight:500;">
                <%= new Date(c.check_out_time).toLocaleTimeString('vi-VN',{hour:'2-digit',minute:'2-digit'}) %>
              </span>
            <% } else { %>
              <span class="badge" style="background:#d8f3dc;color:#1b5e34;border-color:#74c693;font-weight:600;">Đang tập</span>
            <% } %>
          </td>
          <td>
            <% if (c.check_out_time) {
              const mins = Math.round((new Date(c.check_out_time) - new Date(c.check_in_time)) / 60000);
              const h = Math.floor(mins/60), m = mins % 60;
            %>
              <span style="font-weight:700;color:var(--color-moss-dark);">
                <%= h > 0 ? h + 'h ' : '' %><%= m %>p
              </span>
            <% } else { %>
              <span style="color:var(--color-ink-soft);">—</span>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% if (checkins.length > 0) { %>
  <div style="padding:12px 20px;border-top:1px solid var(--color-rail);font-size:0.85rem;color:var(--color-ink-soft);">
    Tổng: <strong><%= checkins.length %></strong> lượt check-in
  </div>
  <% } %>
</div>

<%- include('partials/footer') %>
