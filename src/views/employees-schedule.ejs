<%/* views/employees-schedule.ejs */%>
<%- include('partials/header') %>

<style>
/* ─── SCHEDULE GRID ─── */
.sch-wrap { overflow-x: auto; }
.sch-table { border-collapse: collapse; font-size: 12.5px; min-width: 900px; width: 100%; }
.sch-table th { padding: 10px 12px; background: var(--cream); border: 1px solid var(--line); text-align: center; font-size: 11px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; color: var(--muted); white-space: nowrap; }
.sch-table th.today-col { background: #D8F3DC; color: #1B4332; }
.sch-table td { border: 1px solid var(--line); vertical-align: top; padding: 6px; min-width: 110px; min-height: 70px; background: #fff; }
.sch-table td.emp-name { background: var(--cream); font-weight: 600; font-size: 12.5px; min-width: 140px; padding: 10px 14px; vertical-align: middle; }
.sch-table td.today-col { background: #F6FBF7; }
.sch-table tr:hover td { background: #FAFAF7; }
.sch-table tr:hover td.today-col { background: #EEF8F1; }
.sch-table tr:hover td.emp-name { background: #EAE7DC; }

/* shift pill */
.shift-pill {
  display: flex; align-items: center; justify-content: space-between;
  gap: 4px; padding: 4px 8px; border-radius: 7px;
  font-size: 11px; font-weight: 600; margin-bottom: 4px;
  white-space: nowrap;
}
.shift-pill .shift-time { font-weight: 400; font-size: 10.5px; opacity: .75; }
.shift-pill form { margin: 0; }
.shift-pill button {
  background: none; border: none; cursor: pointer;
  font-size: 13px; line-height:1; padding: 0 2px;
  opacity: .5; transition: opacity .15s;
}
.shift-pill button:hover { opacity: 1; }
.sc-blue   { background: #E6F1FB; color: #0C447C; }
.sc-amber  { background: #FEF3CD; color: #856404; }
.sc-purple { background: #EEEDFE; color: #3C3489; }
.sc-forest { background: #D8F3DC; color: #1B4332; }

/* add form mini */
.add-shift-form { margin-top: 4px; }
.add-shift-form select, .add-shift-form input[type=text] {
  font-size: 11px; padding: 3px 6px; border-radius: 6px;
  border: 1px solid var(--line); width: 100%; margin-bottom: 3px;
}
.add-shift-form button { font-size: 11px; padding: 3px 8px; width: 100%; }

/* legend */
.legend { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:16px; }
.legend-item { display:flex; align-items:center; gap:6px; font-size:12px; }
.legend-dot { width:12px; height:12px; border-radius:4px; }
</style>

<div style="margin-bottom:16px">
  <a href="/employees" class="btn btn-secondary btn-sm">← Quay lại nhân viên</a>
</div>

<div class="page-eyebrow">System Administration › 1.2</div>
<h1 class="page-title">Phân ca làm việc</h1>
<p class="page-sub">Xem và phân ca theo tuần cho từng nhân viên.</p>

<% if (success) { %><div class="alert alert-success"><span class="alert-icon">✓</span><%= success %></div><% } %>
<% if (error)   { %><div class="alert alert-error"><span class="alert-icon">✕</span><%= error %></div><% } %>

<%/* ── ĐIỀU HƯỚNG TUẦN ── */%>
<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;flex-wrap:wrap">
  <a href="/employees/schedule?week=<%= prevWeek %>" class="btn btn-secondary">← Tuần trước</a>
  <span style="font-weight:600;font-size:14px">
    Tuần <%= new Date(weekStart).toLocaleDateString('vi-VN') %> —
         <%= new Date(weekEnd).toLocaleDateString('vi-VN') %>
  </span>
  <a href="/employees/schedule?week=<%= nextWeek %>" class="btn btn-secondary">Tuần sau →</a>
  <a href="/employees/schedule" class="btn btn-warn btn-sm">📅 Tuần này</a>
</div>

<%/* ── CHÚ THÍCH CA ── */%>
<div class="legend" style="margin-bottom:18px">
  <% shifts.forEach(sh => { %>
  <div class="legend-item">
    <div class="legend-dot sc-<%= sh.color %>" style="background:<%= {blue:'#B5D4F4',amber:'#FAC775',purple:'#CECBF6',forest:'#B7E4C7'}[sh.color] %>"></div>
    <span><strong><%= sh.name %></strong> (<%= sh.startTime %>–<%= sh.endTime %>)</span>
  </div>
  <% }) %>
</div>

<%/* ── BẢNG LỊCH TUẦN ── */%>
<div class="card">
  <div class="sch-wrap">
    <table class="sch-table">
      <thead>
        <tr>
          <th>Nhân viên</th>
          <% dateLabels.forEach(dl => { %>
            <th class="<%= dl.isToday ? 'today-col' : '' %>">
              <%= dl.label %>
              <% if (dl.isToday) { %><br><span style="font-size:9px;background:#52B788;color:#fff;padding:1px 5px;border-radius:4px">Hôm nay</span><% } %>
            </th>
          <% }) %>
        </tr>
      </thead>
      <tbody>
        <% employees.filter(e => e.status === 'active').forEach(emp => { %>
        <tr>
          <%/* Tên nhân viên */%>
          <td class="emp-name">
            <div style="display:flex;align-items:center;gap:8px">
              <div style="
                width:28px;height:28px;border-radius:50%;flex-shrink:0;
                display:flex;align-items:center;justify-content:center;
                font-size:10px;font-weight:700;
                background:<%= {green:'#B7E4C7',blue:'#B5D4F4',amber:'#FAC775',purple:'#CECBF6',pink:'#F4C0D1',teal:'#9FE1CB'}[emp.avatarColor]||'#eee' %>;
                color:<%= {green:'#1B4332',blue:'#0C447C',amber:'#633806',purple:'#3C3489',pink:'#72243E',teal:'#085041'}[emp.avatarColor]||'#333' %>;
              "><%= emp.avatar %></div>
              <div>
                <div><%= emp.fullName %></div>
                <div style="font-size:10.5px;color:#999;font-weight:400"><%= emp.position %></div>
              </div>
            </div>
          </td>

          <%/* Mỗi ngày trong tuần */%>
          <% dateLabels.forEach(dl => { %>
          <td class="<%= dl.isToday ? 'today-col' : '' %>">
            <%/* Các ca đã phân */%>
            <% (grid[emp.id] && grid[emp.id][dl.date] ? grid[emp.id][dl.date] : []).forEach(sc => { %>
            <div class="shift-pill sc-<%= sc.shift ? sc.shift.color : 'blue' %>">
              <div>
                <div><%= sc.shift ? sc.shift.name : sc.shiftId %></div>
                <div class="shift-time"><%= sc.shift ? sc.shift.startTime + '–' + sc.shift.endTime : '' %></div>
              </div>
              <form action="/employees/schedule/<%= sc.id %>/delete" method="POST" style="display:inline">
                <input type="hidden" name="week" value="<%= weekStart %>">
                <button type="submit" title="Xóa ca này">✕</button>
              </form>
            </div>
            <% }) %>

            <%/* Form phân ca nhanh */%>
            <div class="add-shift-form">
              <form action="/employees/schedule/assign" method="POST">
                <input type="hidden" name="employeeId" value="<%= emp.id %>">
                <input type="hidden" name="date" value="<%= dl.date %>">
                <input type="hidden" name="week" value="<%= weekStart %>">
                <select name="shiftId">
                  <% shifts.forEach(sh => { %>
                    <option value="<%= sh.id %>"><%= sh.name %></option>
                  <% }) %>
                </select>
                <button type="submit" class="btn btn-secondary btn-sm" style="width:100%;font-size:11px;padding:3px">＋ Thêm ca</button>
              </form>
            </div>
          </td>
          <% }) %>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%/* ── FORM PHÂN CA CHI TIẾT (dành cho nhân viên ngừng hoạt động hoặc phân ca có ghi chú) ── */%>
<div class="card" style="margin-top:24px;max-width:580px">
  <div class="card-header"><span class="card-title">📌 Phân ca nâng cao (có ghi chú)</span></div>
  <div class="card-body">
    <form action="/employees/schedule/assign" method="POST">
      <input type="hidden" name="week" value="<%= weekStart %>">
      <div class="form-grid">
        <div class="form-group">
          <label class="field-label" for="adv-employee">Nhân viên <span class="req">*</span></label>
          <select id="adv-employee" name="employeeId" required>
            <option value="">-- Chọn nhân viên --</option>
            <% employees.forEach(emp => { %>
              <option value="<%= emp.id %>"><%= emp.fullName %> (<%= emp.position %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label class="field-label" for="adv-shift">Ca làm việc <span class="req">*</span></label>
          <select id="adv-shift" name="shiftId" required>
            <% shifts.forEach(sh => { %>
              <option value="<%= sh.id %>"><%= sh.name %> (<%= sh.startTime %>–<%= sh.endTime %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label class="field-label" for="adv-date">Ngày <span class="req">*</span></label>
          <input type="date" id="adv-date" name="date" required>
        </div>
        <div class="form-group">
          <label class="field-label" for="adv-note">Ghi chú</label>
          <input type="text" id="adv-note" name="note" placeholder="Họp, sự kiện...">
        </div>
        <div class="form-group full" style="text-align:right">
          <button type="submit" class="btn btn-primary">📌 Phân ca</button>
        </div>
      </div>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
