<%- include('partials/header') %>

<div class="page-head">
  <div>
    <p class="eyebrow">Huấn luyện viên</p>
    <h1 class="page-title">Cập nhật HLV</h1>
  </div>
  <a href="/trainers" class="btn btn-secondary"><i class="ti ti-arrow-left"></i> Quay lại</a>
</div>

<% if (error) { %><div class="alert alert-error"><i class="ti ti-alert-circle"></i> <%= error %></div><% } %>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start;">

  <div class="card">
    <div class="card-header"><span class="card-title"><i class="ti ti-edit"></i> Thông tin HLV</span></div>
    <div class="card-body">
      <form method="POST" action="/trainers/<%= trainer.id %>/update">
        <div class="form-grid">
          <div class="form-group full">
            <label>Họ tên <span class="req">*</span></label>
            <input type="text" name="full_name" value="<%= trainer.full_name %>" required />
          </div>
          <div class="form-group">
            <label>Chuyên môn</label>
            <input type="text" name="specialization" value="<%= trainer.specialization || '' %>" />
          </div>
          <div class="form-group">
            <label>Ngày vào làm</label>
            <input type="date" name="hire_date" value="<%= trainer.hire_date ? new Date(trainer.hire_date).toISOString().split('T')[0] : '' %>" />
          </div>
          <div class="form-group">
            <label>Số điện thoại</label>
            <input type="text" name="phone" value="<%= trainer.phone || '' %>" />
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" value="<%= trainer.email || '' %>" />
          </div>
          <div class="form-group full">
            <label>Trạng thái</label>
            <select name="status">
              <option value="active" <%= trainer.status==='active'?'selected':'' %>>Đang dạy</option>
              <option value="inactive" <%= trainer.status==='inactive'?'selected':'' %>>Không hoạt động</option>
            </select>
          </div>
        </div>
        <div style="display:flex;gap:10px;margin-top:20px;">
          <button class="btn btn-primary" type="submit"><i class="ti ti-check"></i> Lưu thay đổi</button>
          <a href="/trainers" class="btn btn-secondary">Hủy</a>
        </div>
      </form>
    </div>
  </div>

  <div class="card">
    <div class="card-header"><span class="card-title"><i class="ti ti-calendar"></i> Lịch dạy</span></div>
    <div style="overflow-x:auto;">
      <table class="table">
        <thead><tr><th>Lớp học</th><th>Thứ</th><th>Giờ</th><th>Cấp độ</th></tr></thead>
        <tbody>
          <% if (!schedule.length) { %>
            <tr><td colspan="4" style="text-align:center;color:var(--color-ink-soft);padding:24px;">Chưa có lớp học nào.</td></tr>
          <% } %>
          <% schedule.forEach(c => { %>
          <tr>
            <td><strong><%= c.name %></strong></td>
            <td><%= c.day %></td>
            <td><%= c.time %></td>
            <td><span class="badge"><%= c.level %></span></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<%- include('partials/footer') %>
