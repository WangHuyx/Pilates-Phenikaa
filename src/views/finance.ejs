<%- include('partials/header') %>

<div class="page-head">
  <div>
    <p class="eyebrow">Quản lý</p>
    <h1 class="page-title">Tài chính</h1>
    <p class="lede">Ghi nhận và theo dõi thanh toán</p>
  </div>
</div>

<% if (success) { %>
  <div class="alert alert-success"><i class="ti ti-circle-check"></i> <%= success %></div>
<% } %>
<% if (error) { %>
  <div class="alert alert-error"><i class="ti ti-alert-circle"></i> <%= error %></div>
<% } %>

<!-- Stats row -->
<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:20px;">
  <div class="stat-card">
    <p class="stat-card-label">Tổng đã thu</p>
    <p class="stat-card-value"><%= Number(stats.totalPaid).toLocaleString('vi-VN') %>đ</p>
    <div class="stat-card-icon stat-icon-green"><i class="ti ti-currency-dollar"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Chờ thanh toán</p>
    <p class="stat-card-value"><%= Number(stats.totalPending).toLocaleString('vi-VN') %>đ</p>
    <div class="stat-card-icon stat-icon-amber"><i class="ti ti-clock"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Tổng giao dịch</p>
    <p class="stat-card-value"><%= stats.totalCount %> giao dịch</p>
    <div class="stat-card-icon stat-icon-blue"><i class="ti ti-receipt"></i></div>
  </div>
</div>

<div class="card">
  <!-- Toolbar -->
  <form method="GET" action="/finance" class="finance-toolbar">
    <div class="finance-search-wrap">
      <i class="ti ti-search"></i>
      <input type="text" name="q" value="<%= filterSearch %>" placeholder="Tìm theo tên, mã hóa đơn..." />
    </div>
    <select name="status" class="finance-select" onchange="this.form.submit()">
      <option value=""          <%= filterStatus === ''          ? 'selected' : '' %>>Tất cả trạng thái</option>
      <option value="paid"      <%= filterStatus === 'paid'      ? 'selected' : '' %>>Đã thanh toán</option>
      <option value="pending"   <%= filterStatus === 'pending'   ? 'selected' : '' %>>Chờ thanh toán</option>
      <option value="cancelled" <%= filterStatus === 'cancelled' ? 'selected' : '' %>>Đã hủy</option>
    </select>
    <button class="btn btn-secondary btn-sm" type="submit"><i class="ti ti-filter"></i> Lọc</button>
    <% if (filterSearch || filterStatus) { %>
      <a href="/finance" class="btn btn-secondary btn-sm"><i class="ti ti-x"></i> Xóa lọc</a>
    <% } %>
    <div style="margin-left:auto;display:flex;gap:8px;">
      <button type="button" class="btn btn-primary" onclick="openAddModal()">
        <i class="ti ti-plus"></i> Ghi nhận thanh toán
      </button>
      <a href="/reports/export/finance" class="btn btn-secondary"><i class="ti ti-download"></i> Xuất</a>
    </div>
  </form>

  <div style="overflow-x:auto;">
    <table class="table">
      <thead>
        <tr>
          <th>Hóa đơn</th>
          <th>Hội viên</th>
          <th>Gói tập</th>
          <th>Loại</th>
          <th>Ngày</th>
          <th>Số tiền</th>
          <th>Phương thức</th>
          <th>Trạng thái</th>
          <th>Thao tác</th>
        </tr>
      </thead>
      <tbody>
        <% if (payments.length === 0) { %>
          <tr><td colspan="9" style="text-align:center;color:var(--color-ink-soft);padding:32px;">Không có giao dịch nào.</td></tr>
        <% } %>
        <% payments.forEach(p => { %>
          <tr>
            <td><code class="invoice-code"><%= p.invoice_code || ('HD-' + String(p.id).padStart(4,'0')) %></code></td>
            <td><strong><%= p.full_name %></strong></td>
            <td><%= p.package_name || '—' %></td>
            <td><%= p.type === 'pt' ? 'PT' : p.type === 'other' ? 'Khác' : 'Đăng ký mới' %></td>
            <td><%= new Date(p.payment_date).toLocaleDateString('vi-VN') %></td>
            <td style="font-weight:600;color:var(--color-moss-dark);"><%= Number(p.amount).toLocaleString('vi-VN') %>đ</td>
            <td>
              <span class="badge"><%= p.payment_method === 'cash' ? 'Tiền mặt' : p.payment_method === 'transfer' ? 'Chuyển khoản' : p.payment_method === 'card' ? 'Thẻ' : p.payment_method %></span>
            </td>
            <td>
              <span class="badge <%= p.status === 'paid' ? 'badge-paid' : p.status === 'pending' ? 'badge-pending' : 'badge-cancelled' %>">
                <% if (p.status === 'paid') { %><i class="ti ti-circle-check"></i> Đã thanh toán
                <% } else if (p.status === 'pending') { %><i class="ti ti-clock"></i> Chờ thanh toán
                <% } else { %><i class="ti ti-ban"></i> Đã hủy<% } %>
              </span>
            </td>
            <td>
              <div class="action-buttons">
                <button type="button" class="btn-icon" title="Xem hóa đơn" onclick="viewPayment(<%= JSON.stringify({
                  invoice: p.invoice_code || ('HD-' + String(p.id).padStart(4,'0')),
                  member: p.full_name, package: p.package_name || '—',
                  type: p.type === 'pt' ? 'PT' : p.type === 'other' ? 'Khác' : 'Đăng ký mới',
                  amount: Number(p.amount).toLocaleString('vi-VN') + 'đ',
                  date: new Date(p.payment_date).toLocaleDateString('vi-VN'),
                  method: p.payment_method === 'cash' ? 'Tiền mặt' : p.payment_method === 'transfer' ? 'Chuyển khoản' : p.payment_method === 'card' ? 'Thẻ' : p.payment_method,
                  status: p.status === 'paid' ? 'Đã thanh toán' : p.status === 'pending' ? 'Chờ thanh toán' : 'Đã hủy',
                  statusClass: p.status === 'paid' ? 'badge-paid' : p.status === 'pending' ? 'badge-pending' : 'badge-cancelled',
                  note: p.note || 'Không có ghi chú',
                }) %>)"><i class="ti ti-eye"></i></button>
                <form method="POST" action="/finance/<%= p.id %>/delete" onsubmit="return confirm('Xóa giao dịch này?')">
                  <button class="btn-icon btn-danger" type="submit" title="Xóa"><i class="ti ti-trash"></i></button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
      <% if (payments.length > 0) { %>
      <tfoot>
        <tr>
          <td colspan="9" style="text-align:right;padding:14px 16px;color:var(--color-ink-soft);">
            Tổng đã thu (đang lọc): <strong style="color:var(--color-moss-dark);"><%= Number(filteredPaidTotal).toLocaleString('vi-VN') %>đ</strong>
          </td>
        </tr>
      </tfoot>
      <% } %>
    </table>
  </div>
</div>

<!-- ══════════════ Modal: Ghi nhận thanh toán ══════════════ -->
<div id="add-modal" class="pkg-modal-overlay" onclick="if(event.target===this)closeAddModal()">
  <div class="pkg-modal">
    <div class="pkg-modal-header">
      <h3><i class="ti ti-plus"></i> Ghi nhận thanh toán</h3>
      <button type="button" class="pkg-modal-close" onclick="closeAddModal()"><i class="ti ti-x"></i></button>
    </div>
    <form method="POST" action="/finance">
      <div class="form-grid">
        <div class="form-group">
          <label>Hội viên <span class="req">*</span></label>
          <select name="user_id" required>
            <option value="">-- Chọn hội viên --</option>
            <% members.forEach(m => { %>
              <option value="<%= m.id %>"><%= m.full_name %> (<%= m.username %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Gói tập</label>
          <select name="package_id">
            <option value="">-- Không gắn gói --</option>
            <% packages.forEach(pkg => { %>
              <option value="<%= pkg.id %>"><%= pkg.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Loại giao dịch</label>
          <select name="type">
            <option value="registration">Đăng ký mới</option>
            <option value="pt">PT</option>
            <option value="other">Khác</option>
          </select>
        </div>
        <div class="form-group">
          <label>Số tiền (VNĐ) <span class="req">*</span></label>
          <input type="number" name="amount" placeholder="VD: 500000" min="0" required />
        </div>
        <div class="form-group">
          <label>Ngày thanh toán <span class="req">*</span></label>
          <input type="date" name="payment_date" required value="<%= new Date().toISOString().split('T')[0] %>" />
        </div>
        <div class="form-group">
          <label>Phương thức</label>
          <select name="payment_method">
            <option value="cash">Tiền mặt</option>
            <option value="transfer">Chuyển khoản</option>
            <option value="card">Thẻ</option>
          </select>
        </div>
        <div class="form-group">
          <label>Trạng thái</label>
          <select name="status">
            <option value="paid">Đã thanh toán</option>
            <option value="pending">Chờ thanh toán</option>
          </select>
        </div>
        <div class="form-group full">
          <label>Ghi chú</label>
          <input type="text" name="note" placeholder="Ghi chú..." />
        </div>
      </div>
      <div style="display:flex;gap:10px;margin-top:18px;">
        <button class="btn btn-primary" type="submit"><i class="ti ti-check"></i> Lưu giao dịch</button>
        <button class="btn btn-secondary" type="button" onclick="closeAddModal()">Hủy</button>
      </div>
    </form>
  </div>
</div>

<!-- ══════════════ Modal: Hóa đơn thanh toán ══════════════ -->
<div id="bill-modal" class="pkg-modal-overlay" onclick="if(event.target===this)closeBillModal()">
  <div class="pkg-modal bill-card">
    <div class="pkg-modal-header no-print">
      <h3><i class="ti ti-receipt"></i> Hóa đơn thanh toán</h3>
      <button type="button" class="pkg-modal-close" onclick="closeBillModal()"><i class="ti ti-x"></i></button>
    </div>
    <div class="bill-body">
      <div class="bill-brand">
        <div class="bill-brand-icon">🌿</div>
        <div>
          <div class="bill-brand-name">Pilates Phenikaa</div>
          <div class="bill-brand-sub">Hóa đơn thanh toán</div>
        </div>
      </div>
      <div class="bill-invoice-row">
        <code class="invoice-code" id="bill-invoice"></code>
        <span class="badge" id="bill-status"></span>
      </div>
      <div class="bill-divider"></div>
      <div class="bill-row"><span>Hội viên</span><strong id="bill-member"></strong></div>
      <div class="bill-row"><span>Gói tập</span><strong id="bill-package"></strong></div>
      <div class="bill-row"><span>Loại giao dịch</span><strong id="bill-type"></strong></div>
      <div class="bill-row"><span>Ngày thanh toán</span><strong id="bill-date"></strong></div>
      <div class="bill-row"><span>Phương thức</span><strong id="bill-method"></strong></div>
      <div class="bill-divider"></div>
      <div class="bill-total-row"><span>Tổng tiền</span><span class="bill-amount" id="bill-amount"></span></div>
      <p class="bill-note"><i class="ti ti-note"></i> <span id="bill-note"></span></p>
    </div>
    <div class="bill-actions no-print">
      <button class="btn btn-primary" type="button" onclick="window.print()"><i class="ti ti-printer"></i> In hóa đơn</button>
      <button class="btn btn-secondary" type="button" onclick="closeBillModal()">Đóng</button>
    </div>
  </div>
</div>

<script>
function openAddModal() {
  document.getElementById('add-modal').style.display = 'flex';
}
function closeAddModal() {
  document.getElementById('add-modal').style.display = 'none';
}
function closeBillModal() {
  document.getElementById('bill-modal').style.display = 'none';
}
function viewPayment(p) {
  document.getElementById('bill-invoice').textContent = p.invoice;
  document.getElementById('bill-member').textContent  = p.member;
  document.getElementById('bill-package').textContent = p.package;
  document.getElementById('bill-type').textContent    = p.type;
  document.getElementById('bill-date').textContent    = p.date;
  document.getElementById('bill-method').textContent  = p.method;
  document.getElementById('bill-amount').textContent  = p.amount;
  document.getElementById('bill-note').textContent    = p.note;
  var statusEl = document.getElementById('bill-status');
  statusEl.textContent = p.status;
  statusEl.className = 'badge ' + p.statusClass;
  document.getElementById('bill-modal').style.display = 'flex';
}
<% if (error) { %>
openAddModal();
<% } %>
</script>

<%- include('partials/footer') %>
