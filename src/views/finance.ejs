<%- include('partials/header') %>

<div class="page-head">
  <div>
    <p class="eyebrow">Quản lý</p>
    <h1 class="page-title">Tài chính</h1>
    <p class="lede">Theo dõi thu chi và thanh toán gói tập</p>
  </div>
</div>

<% if (success) { %>
  <div class="alert alert-success"><i class="ti ti-circle-check"></i> <%= success %></div>
<% } %>
<% if (error) { %>
  <div class="alert alert-error"><i class="ti ti-alert-circle"></i> <%= error %></div>
<% } %>

<!-- Stats row -->
<div class="stats-grid" style="margin-bottom:20px;">
  <div class="stat-card">
    <p class="stat-card-label">Doanh thu tháng này</p>
    <p class="stat-card-value"><%= Number(thisMonth.revenue).toLocaleString('vi-VN') %>đ</p>
    <div class="stat-card-icon stat-icon-green"><i class="ti ti-currency-dollar"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Chờ thanh toán</p>
    <p class="stat-card-value"><%= Number(thisMonth.pending).toLocaleString('vi-VN') %>đ</p>
    <div class="stat-card-icon stat-icon-amber"><i class="ti ti-clock"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Giao dịch tháng này</p>
    <p class="stat-card-value"><%= thisMonth.count %></p>
    <div class="stat-card-icon stat-icon-blue"><i class="ti ti-receipt"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Tổng doanh thu</p>
    <p class="stat-card-value"><%= Number(totalRevenue).toLocaleString('vi-VN') %>đ</p>
    <div class="stat-card-icon stat-icon-orange"><i class="ti ti-chart-bar"></i></div>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 320px;gap:20px;align-items:start;">

  <!-- Bảng giao dịch -->
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="ti ti-receipt"></i> Danh sách giao dịch</span>
    </div>

    <!-- Toolbar lọc -->
    <form method="GET" action="/finance" class="finance-toolbar">
      <div class="finance-search-wrap">
        <i class="ti ti-search"></i>
        <input type="text" name="q" value="<%= filterSearch %>" placeholder="Tìm theo tên hoặc mã hóa đơn..." />
      </div>
      <select name="status" class="finance-select">
        <option value=""   <%= filterStatus === ''          ? 'selected' : '' %>>Tất cả trạng thái</option>
        <option value="paid"    <%= filterStatus === 'paid'    ? 'selected' : '' %>>Đã thanh toán</option>
        <option value="pending" <%= filterStatus === 'pending' ? 'selected' : '' %>>Chờ thanh toán</option>
        <option value="cancelled" <%= filterStatus === 'cancelled' ? 'selected' : '' %>>Đã hủy</option>
      </select>
      <input type="month" name="month" value="<%= filterMonth %>" class="finance-month" />
      <button class="btn btn-primary btn-sm" type="submit"><i class="ti ti-filter"></i> Lọc</button>
      <% if (filterSearch || filterStatus || filterMonth) { %>
        <a href="/finance" class="btn btn-secondary btn-sm"><i class="ti ti-x"></i> Xóa lọc</a>
      <% } %>
    </form>

    <!-- Tabs trạng thái nhanh -->
    <div class="finance-status-tabs">
      <a href="/finance?<%= filterMonth ? 'month='+filterMonth+'&' : '' %><%= filterSearch ? 'q='+encodeURIComponent(filterSearch)+'&' : '' %>"
         class="finance-tab <%= filterStatus === '' ? 'active' : '' %>">Tất cả</a>
      <a href="/finance?<%= filterMonth ? 'month='+filterMonth+'&' : '' %><%= filterSearch ? 'q='+encodeURIComponent(filterSearch)+'&' : '' %>status=paid"
         class="finance-tab finance-tab-paid <%= filterStatus === 'paid' ? 'active' : '' %>">Đã thanh toán</a>
      <a href="/finance?<%= filterMonth ? 'month='+filterMonth+'&' : '' %><%= filterSearch ? 'q='+encodeURIComponent(filterSearch)+'&' : '' %>status=pending"
         class="finance-tab finance-tab-pending <%= filterStatus === 'pending' ? 'active' : '' %>">Chờ thanh toán</a>
      <a href="/finance?<%= filterMonth ? 'month='+filterMonth+'&' : '' %><%= filterSearch ? 'q='+encodeURIComponent(filterSearch)+'&' : '' %>status=cancelled"
         class="finance-tab finance-tab-cancelled <%= filterStatus === 'cancelled' ? 'active' : '' %>">Đã hủy</a>
      <span class="finance-tab-count"><%= payments.length %> giao dịch</span>
    </div>

    <div style="overflow-x:auto;">
      <table class="table">
        <thead>
          <tr>
            <th>Mã hóa đơn</th>
            <th>Hội viên</th>
            <th>Số tiền</th>
            <th>Ngày</th>
            <th>Phương thức</th>
            <th>Trạng thái</th>
            <th>Ghi chú</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% if (payments.length === 0) { %>
            <tr><td colspan="8" style="text-align:center;color:var(--color-ink-soft);padding:32px;">Không có giao dịch nào.</td></tr>
          <% } %>
          <% payments.forEach(p => { %>
            <tr>
              <td><code class="invoice-code"><%= p.invoice_code || ('HD-' + String(p.id).padStart(4,'0')) %></code></td>
              <td><strong><%= p.full_name %></strong></td>
              <td style="font-weight:600;color:var(--color-moss-dark);"><%= Number(p.amount).toLocaleString('vi-VN') %>đ</td>
              <td><%= new Date(p.payment_date).toLocaleDateString('vi-VN') %></td>
              <td>
                <span class="badge"><%= p.payment_method === 'cash' ? 'Tiền mặt' : p.payment_method === 'transfer' ? 'Chuyển khoản' : p.payment_method === 'card' ? 'Thẻ' : p.payment_method %></span>
              </td>
              <td>
                <span class="badge <%= p.status === 'paid' ? 'badge-paid' : p.status === 'pending' ? 'badge-pending' : 'badge-cancelled' %>">
                  <% if (p.status === 'paid') { %><i class="ti ti-circle-check"></i> Đã thanh toán
                  <% } else if (p.status === 'pending') { %><i class="ti ti-clock"></i> Chờ thanh toán
                  <% } else { %><i class="ti ti-ban"></i> Đã hủy<% } %>
                </span>
              </td>
              <td style="color:var(--color-ink-soft);font-size:0.88rem;"><%= p.note || '—' %></td>
              <td>
                <form method="POST" action="/finance/<%= p.id %>/delete" onsubmit="return confirm('Xóa giao dịch này?')">
                  <button class="btn-icon btn-danger" type="submit" title="Xóa"><i class="ti ti-trash"></i></button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Right column -->
  <div style="display:flex;flex-direction:column;gap:20px;">

    <!-- Form thêm giao dịch -->
    <div class="card">
      <div class="card-header">
        <span class="card-title"><i class="ti ti-plus"></i> Ghi nhận thanh toán</span>
      </div>
      <div class="card-body">
        <form method="POST" action="/finance">
          <div class="form-group">
            <label>Hội viên <span class="req">*</span></label>
            <select name="user_id" required>
              <option value="">-- Chọn hội viên --</option>
              <% members.forEach(m => { %>
                <option value="<%= m.id %>"><%= m.full_name %> (<%= m.username %>)</option>
              <% }) %>
            </select>
          </div>
          <div class="form-group" style="margin-top:12px;">
            <label>Số tiền (VNĐ) <span class="req">*</span></label>
            <input type="number" name="amount" placeholder="VD: 500000" min="0" required />
          </div>
          <div class="form-group" style="margin-top:12px;">
            <label>Ngày thanh toán <span class="req">*</span></label>
            <input type="date" name="payment_date" required value="<%= new Date().toISOString().split('T')[0] %>" />
          </div>
          <div class="form-group" style="margin-top:12px;">
            <label>Phương thức</label>
            <select name="payment_method">
              <option value="cash">Tiền mặt</option>
              <option value="transfer">Chuyển khoản</option>
              <option value="card">Thẻ</option>
            </select>
          </div>
          <div class="form-group" style="margin-top:12px;">
            <label>Trạng thái</label>
            <select name="status">
              <option value="paid">Đã thanh toán</option>
              <option value="pending">Chờ thanh toán</option>
            </select>
          </div>
          <div class="form-group" style="margin-top:12px;">
            <label>Ghi chú</label>
            <input type="text" name="note" placeholder="Ghi chú..." />
          </div>
          <button class="btn btn-primary" type="submit" style="margin-top:16px;width:100%;">
            <i class="ti ti-check"></i> Lưu giao dịch
          </button>
        </form>
      </div>
    </div>

    <!-- Tổng hợp theo tháng -->
    <div class="card">
      <div class="card-header">
        <span class="card-title"><i class="ti ti-chart-bar"></i> Theo tháng</span>
      </div>
      <div style="overflow-x:auto;">
        <table class="table">
          <thead>
            <tr><th>Tháng</th><th>Doanh thu</th><th>GD</th></tr>
          </thead>
          <tbody>
            <% if (summary.length === 0) { %>
              <tr><td colspan="3" style="text-align:center;color:var(--color-ink-soft);padding:20px;">Chưa có dữ liệu.</td></tr>
            <% } %>
            <% summary.forEach(s => { %>
              <tr>
                <td><%= s.month %></td>
                <td style="color:var(--color-moss-dark);font-weight:600;"><%= Number(s.revenue).toLocaleString('vi-VN') %>đ</td>
                <td><%= s.count %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
