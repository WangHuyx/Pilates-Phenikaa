<%- include('../partials/header') %>

<div class="page-head">
  <div>
    <p class="eyebrow">Hội viên</p>
    <h1 class="page-title">Lịch sử — <%= member.fullName %></h1>
    <p class="lede">Toàn bộ hoạt động tập luyện và giao dịch của hội viên</p>
  </div>
  <a href="/accounts" class="btn btn-secondary"><i class="ti ti-arrow-left"></i> Quay lại</a>
</div>

<!-- Stats -->
<div class="stats-grid" style="margin-bottom:20px;">
  <div class="stat-card">
    <p class="stat-card-label">Lớp đã đăng ký</p>
    <p class="stat-card-value"><%= bookings.length %></p>
    <div class="stat-card-icon stat-icon-blue"><i class="ti ti-calendar"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Gói tập</p>
    <p class="stat-card-value"><%= memberships.length %></p>
    <div class="stat-card-icon stat-icon-amber"><i class="ti ti-package"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Tổng thanh toán</p>
    <p class="stat-card-value"><%= Number(payments.reduce((s,p)=>s+(p.status==='paid'?Number(p.amount):0),0)).toLocaleString('vi-VN') %>đ</p>
    <div class="stat-card-icon stat-icon-orange"><i class="ti ti-coin"></i></div>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

  <!-- Gói tập đang dùng -->
  <div class="card">
    <div class="card-header"><span class="card-title"><i class="ti ti-package"></i> Gói tập</span></div>
    <div style="overflow-x:auto;">
      <table class="table">
        <thead><tr><th>Gói</th><th>Từ ngày</th><th>Đến ngày</th><th>Trạng thái</th></tr></thead>
        <tbody>
          <% if (!memberships.length) { %>
            <tr><td colspan="4" style="text-align:center;color:var(--color-ink-soft);padding:20px;">Chưa có gói tập.</td></tr>
          <% } %>
          <% memberships.forEach(m => { const expired = m.end_date && new Date(m.end_date)<new Date(); %>
          <tr>
            <td><strong><%= m.package_name %></strong><br><span style="font-size:0.8rem;color:var(--color-ink-soft);"><%= Number(m.price).toLocaleString('vi-VN') %>đ</span></td>
            <td style="font-size:0.88rem;"><%= new Date(m.start_date).toLocaleDateString('vi-VN') %></td>
            <td style="font-size:0.88rem;"><%= new Date(m.end_date).toLocaleDateString('vi-VN') %></td>
            <td><span class="badge" style="<%= expired?'background:#fbeae8;color:#c0392b;border-color:#f0b8b4':'background:#d8f3dc;color:#1b5e34;border-color:#74c693' %>"><%= expired?'Hết hạn':'Còn hạn' %></span></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Lớp học đã đăng ký -->
  <div class="card">
    <div class="card-header"><span class="card-title"><i class="ti ti-calendar"></i> Lớp học đã đăng ký</span></div>
    <div style="overflow-x:auto;">
      <table class="table">
        <thead><tr><th>Lớp</th><th>HLV</th><th>Thứ</th><th>Giờ</th></tr></thead>
        <tbody>
          <% if (!bookings.length) { %>
            <tr><td colspan="4" style="text-align:center;color:var(--color-ink-soft);padding:20px;">Chưa đăng ký lớp nào.</td></tr>
          <% } %>
          <% bookings.forEach(b => { %>
          <tr>
            <td><strong><%= b.name %></strong></td>
            <td style="font-size:0.88rem;"><%= b.instructor %></td>
            <td><%= b.day %></td>
            <td><%= b.time %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<!-- Lịch sử thanh toán -->
<div class="card">
  <div class="card-header"><span class="card-title"><i class="ti ti-receipt"></i> Lịch sử thanh toán</span></div>
  <div style="overflow-x:auto;">
    <table class="table">
      <thead><tr><th>Ngày</th><th>Số tiền</th><th>Phương thức</th><th>Trạng thái</th></tr></thead>
      <tbody>
        <% if (!payments.length) { %>
          <tr><td colspan="4" style="text-align:center;color:var(--color-ink-soft);padding:20px;">Chưa có giao dịch.</td></tr>
        <% } %>
        <% payments.forEach(p => { %>
        <tr>
          <td style="font-size:0.88rem;"><%= new Date(p.payment_date).toLocaleDateString('vi-VN') %></td>
          <td style="font-weight:600;color:var(--color-moss-dark);"><%= Number(p.amount).toLocaleString('vi-VN') %>đ</td>
          <td><span class="badge"><%= p.payment_method==='cash'?'Tiền mặt':'Chuyển khoản' %></span></td>
          <td>
            <span class="badge" style="<%= p.status==='paid'?'background:#d8f3dc;color:#1b5e34;border-color:#74c693':'background:#fff3cd;color:#7c4700;border-color:#f0d06b' %>">
              <%= p.status==='paid'?'Đã thanh toán':'Chờ TT' %>
            </span>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
