<%- include('partials/header') %>

<div class="page-head">
  <div>
    <p class="eyebrow">Quản lý</p>
    <h1 class="page-title">Thiết bị</h1>
    <p class="lede">Quản lý danh sách và số lượng máy tập</p>
  </div>
</div>

<% if (typeof success !== 'undefined' && success) { %><div class="alert alert-success"><i class="ti ti-circle-check"></i> <%= success %></div><% } %>
<% if (typeof error !== 'undefined' && error) { %><div class="alert alert-error"><i class="ti ti-alert-circle"></i> <%= error %></div><% } %>

<div class="stats-grid" style="margin-bottom:20px;">
  <div class="stat-card">
    <p class="stat-card-label">Đang hoạt động</p>
    <p class="stat-card-value"><%= counts.active || 0 %></p>
    <div class="stat-card-icon stat-icon-green"><i class="ti ti-check"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Đang bảo trì</p>
    <p class="stat-card-value"><%= counts.maintenance || 0 %></p>
    <div class="stat-card-icon stat-icon-amber"><i class="ti ti-tool"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Ngưng hoạt động</p>
    <p class="stat-card-value"><%= counts.retired || 0 %></p>
    <div class="stat-card-icon stat-icon-orange"><i class="ti ti-archive"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Tổng số máy tập</p>
    <p class="stat-card-value"><%= equipment.length || 0 %></p>
    <div class="stat-card-icon stat-icon-blue"><i class="ti ti-device-desktop"></i></div>
  </div>
</div>

<div class="card">
    <div class="card-header">
      <span class="card-title"><i class="ti ti-list"></i> Danh sách thiết bị</span>
      <div style="display:flex;gap:8px;">
        <a href="/equipment" class="btn btn-sm <%= (!typeof filterStatus || filterStatus === 'all') ? 'btn-primary' : 'btn-secondary' %>">Tất cả</a>
        <a href="/equipment?status=active" class="btn btn-sm <%= (typeof filterStatus !== 'undefined' && filterStatus === 'active') ? 'btn-primary' : 'btn-secondary' %>">Hoạt động</a>
        <button type="button" class="btn btn-sm btn-primary" onclick="openAddModal()"><i class="ti ti-plus"></i> Thêm thiết bị</button>
      </div>
    </div>
    
    <div class="finance-toolbar" style="border-top:none;padding:12px 20px;">
      <div class="finance-search-wrap" style="max-width:340px;">
        <i class="ti ti-search"></i>
        <input type="text" id="eq-search" placeholder="Tìm theo tên, loại hoặc số hiệu..." oninput="filterEquipment(this.value)" />
      </div>
      <span id="eq-count" style="font-size:0.82rem;color:var(--color-ink-soft);margin-left:auto;"><%= equipment.length %> thiết bị</span>
    </div>

    <div style="overflow-x:auto;">
      <table class="table">
        <thead>
          <tr><th>Tên thiết bị</th><th>Loại</th><th>Số hiệu</th><th>Trạng thái</th><th>Thao tác</th></tr>
        </thead>
        <tbody id="eq-tbody">
          <% if (!equipment || !equipment.length) { %>
            <tr><td colspan="5" style="text-align:center;color:var(--color-ink-soft);padding:32px;">Chưa có thiết bị nào.</td></tr>
          <% } else { %>
            <% equipment.forEach(e => { %>
            <tr>
              <td><strong><%= e.name %></strong><% if(e.notes){ %><br><span style="font-size:0.8rem;color:var(--color-ink-soft);"><%= e.notes %></span><% } %></td>
              <td><span class="badge"><%= {reformer:'Reformer',cadillac:'Cadillac',chair:'Chair',barrel:'Barrel',tower:'Tower',other:'Khác'}[e.type]||e.type %></span></td>
              <td style="font-family:var(--font-mono);font-size:0.85rem;"><%= e.serial_number || '—' %></td>
              <td>
                <% const statusMap = {active:['Hoạt động','#d8f3dc','#1b5e34','#74c693'],maintenance:['Bảo trì','#fff3cd','#7c4700','#f0d06b'],retired:['Ngưng','#fbeae8','#c0392b','#f0b8b4']}; %>
                <% const [sLabel,sBg,sColor,sBorder] = statusMap[e.status]||statusMap.active; %>
                <span class="badge" style="background:<%= sBg %>;color:<%= sColor %>;border-color:<%= sBorder %>"><%= sLabel %></span>
              </td>
              <td>
                <div style="display:flex;gap:6px;">
                  <button class="btn-icon" title="Sửa" onclick="openEditModal(<%= JSON.stringify(e) %>)"><i class="ti ti-edit"></i></button>
                  <form method="POST" action="/equipment/<%= e.id %>/delete" style="margin:0;" onsubmit="return confirm('Xóa thiết bị này?')">
                    <button class="btn-icon btn-danger" type="submit"><i class="ti ti-trash"></i></button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

<div id="add-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:12px;padding:28px;width:400px;max-width:90vw;">
    <h3 style="margin:0 0 16px;font-size:1rem;"><i class="ti ti-plus"></i> Thêm thiết bị</h3>
    <form method="POST" action="/equipment/create">
      <div class="form-group">
        <label>Tên thiết bị <span class="req">*</span></label>
        <input type="text" name="name" placeholder="Ví dụ: Reformer #4" required />
      </div>
      <div class="form-group" style="margin-top:12px;">
        <label>Loại máy</label>
        <select name="type">
          <option value="reformer">Reformer</option>
          <option value="cadillac">Cadillac</option>
          <option value="chair">Wunda Chair</option>
          <option value="barrel">Barrel</option>
          <option value="tower">Tower</option>
          <option value="other">Khác</option>
        </select>
      </div>
      <div class="form-group" style="margin-top:12px;">
        <label>Số hiệu (S/N)</label>
        <input type="text" name="serial_number" placeholder="RF-004" />
      </div>
      <div class="form-group" style="margin-top:12px;">
        <label>Trạng thái</label>
        <select name="status">
          <option value="active">Hoạt động</option>
          <option value="maintenance">Đang bảo trì</option>
          <option value="retired">Ngưng hoạt động</option>
        </select>
      </div>
      <div class="form-group" style="margin-top:12px;">
        <label>Ghi chú thêm</label>
        <input type="text" name="notes" placeholder="Tình trạng, vị trí..." />
      </div>
      <div style="display:flex;gap:10px;margin-top:18px;">
        <button class="btn btn-primary" type="submit"><i class="ti ti-plus"></i> Lưu thiết bị</button>
        <button class="btn btn-secondary" type="button" onclick="closeAddModal()">Hủy</button>
      </div>
    </form>
  </div>
</div>

<div id="edit-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:12px;padding:28px;width:400px;max-width:90vw;">
    <h3 style="margin:0 0 16px;font-size:1rem;">Cập nhật thông tin</h3>
    <form method="POST" id="edit-form">
      <div class="form-group"><label>Tên</label><input type="text" name="name" id="edit-name" required /></div>
      <div class="form-group" style="margin-top:10px;"><label>Loại</label>
        <select name="type" id="edit-type">
          <option value="reformer">Reformer</option><option value="cadillac">Cadillac</option>
          <option value="chair">Wunda Chair</option><option value="barrel">Barrel</option>
          <option value="tower">Tower</option><option value="other">Khác</option>
        </select>
      </div>
      <div class="form-group" style="margin-top:10px;"><label>Số hiệu</label><input type="text" name="serial_number" id="edit-serial" /></div>
      <div class="form-group" style="margin-top:10px;"><label>Trạng thái</label>
        <select name="status" id="edit-status">
          <option value="active">Hoạt động</option><option value="maintenance">Bảo trì</option><option value="retired">Ngưng</option>
        </select>
      </div>
      <div class="form-group" style="margin-top:10px;"><label>Ghi chú</label><input type="text" name="notes" id="edit-notes" /></div>
      <div style="display:flex;gap:10px;margin-top:18px;">
        <button class="btn btn-primary" type="submit">Lưu thay đổi</button>
        <button class="btn btn-secondary" type="button" onclick="closeEditModal()">Hủy</button>
      </div>
    </form>
  </div>
</div>

<script>
function filterEquipment(q) {
  var rows = document.querySelectorAll('#eq-tbody tr');
  var term = q.trim().toLowerCase();
  var visible = 0;
  rows.forEach(function(row) {
    var text = row.textContent.toLowerCase();
    var show = !term || text.indexOf(term) !== -1;
    row.style.display = show ? '' : 'none';
    if (show) visible++;
  });
  document.getElementById('eq-count').textContent = visible + ' thiết bị';
}

function openEditModal(eq) {
  document.getElementById('edit-name').value = eq.name;
  document.getElementById('edit-type').value = eq.type;
  document.getElementById('edit-serial').value = eq.serial_number || '';
  document.getElementById('edit-status').value = eq.status;
  document.getElementById('edit-notes').value = eq.notes || '';
  document.getElementById('edit-form').action = '/equipment/' + eq.id + '/update';
  var m = document.getElementById('edit-modal');
  m.style.display = 'flex';
}
function closeEditModal() { document.getElementById('edit-modal').style.display = 'none'; }
document.getElementById('edit-modal').addEventListener('click', function(e){ if(e.target===this) closeEditModal(); });

function openAddModal() { document.getElementById('add-modal').style.display = 'flex'; }
function closeAddModal() { document.getElementById('add-modal').style.display = 'none'; }
document.getElementById('add-modal').addEventListener('click', function(e){ if(e.target===this) closeAddModal(); });
<% if (typeof error !== 'undefined' && error) { %>
openAddModal();
<% } %>
</script>

<%- include('partials/footer') %>