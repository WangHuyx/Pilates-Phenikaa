<%- include('partials/header') %>

<div class="page-head">
  <div>
    <p class="eyebrow">Quản lý</p>
    <h1 class="page-title">Thiết bị</h1>
    <p class="lede">Quản lý máy tập và lịch bảo trì</p>
  </div>
</div>

<% if (success) { %><div class="alert alert-success"><i class="ti ti-circle-check"></i> <%= success %></div><% } %>
<% if (error) { %><div class="alert alert-error"><i class="ti ti-alert-circle"></i> <%= error %></div><% } %>

<% if (overdueItems.length > 0) { %>
<div class="alert" style="background:#fff3cd;border-color:#f0d06b;color:#7c4700;margin-bottom:20px;">
  <i class="ti ti-alert-triangle"></i>
  <strong><%= overdueItems.length %> thiết bị</strong> có lịch bảo trì đã quá hạn!
  <% overdueItems.forEach(o => { %><span style="margin-left:8px;">· <%= o.equipment_name %></span><% }) %>
</div>
<% } %>

<% if (upcoming.length > 0) { %>
<div class="alert alert-info" style="background:#E3F2FD;border-color:#90CAF9;color:#1565C0;margin-bottom:20px;">
  <i class="ti ti-clock"></i>
  <strong><%= upcoming.length %> lịch bảo trì</strong> trong 7 ngày tới:
  <% upcoming.forEach(u => { %>
    <span style="margin-left:8px;">· <%= u.equipment_name %> (<%= new Date(u.scheduled_date).toLocaleDateString('vi-VN') %>)</span>
  <% }) %>
</div>
<% } %>

<!-- Stats -->
<div class="stats-grid" style="margin-bottom:20px;">
  <div class="stat-card">
    <p class="stat-card-label">Đang hoạt động</p>
    <p class="stat-card-value"><%= counts.active %></p>
    <div class="stat-card-icon stat-icon-green"><i class="ti ti-check"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Đang bảo trì</p>
    <p class="stat-card-value"><%= counts.maintenance %></p>
    <div class="stat-card-icon stat-icon-amber"><i class="ti ti-tool"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Ngưng hoạt động</p>
    <p class="stat-card-value"><%= counts.retired %></p>
    <div class="stat-card-icon stat-icon-orange"><i class="ti ti-archive"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Bảo trì quá hạn</p>
    <p class="stat-card-value"><%= overdueItems.length %></p>
    <div class="stat-card-icon stat-icon-blue" style="background:#fbeae8;color:#c0392b;"><i class="ti ti-alert-circle"></i></div>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 320px;gap:20px;align-items:start;">

  <div style="display:flex;flex-direction:column;gap:20px;">

    <!-- Danh sách thiết bị -->
    <div class="card">
      <div class="card-header">
        <span class="card-title"><i class="ti ti-device-desktop"></i> Danh sách thiết bị</span>
        <div style="display:flex;gap:8px;">
          <a href="/equipment" class="btn btn-sm <%= filterStatus==='all'?'btn-primary':'btn-secondary' %>">Tất cả</a>
          <a href="/equipment?status=active" class="btn btn-sm <%= filterStatus==='active'?'btn-primary':'btn-secondary' %>">Hoạt động</a>
          <a href="/equipment?status=maintenance" class="btn btn-sm <%= filterStatus==='maintenance'?'btn-primary':'btn-secondary' %>">Bảo trì</a>
        </div>
      </div>
      <div class="finance-toolbar" style="border-top:none;padding:12px 20px;">
        <div class="finance-search-wrap" style="max-width:340px;">
          <i class="ti ti-search"></i>
          <input type="text" id="eq-search" placeholder="Tìm theo tên, loại hoặc số hiệu..." oninput="filterEquipment(this.value)" />
        </div>
        <span id="eq-count" style="font-size:0.82rem;color:var(--color-ink-soft);margin-left:auto;"><%= equipment.length %> thiết bị</span>
      </div>
      <div style="overflow-x:auto;">
        <table class="table">
          <thead><tr><th>Tên thiết bị</th><th>Loại</th><th>Số hiệu</th><th>Trạng thái</th><th></th></tr></thead>
          <tbody id="eq-tbody">
            <% if (!equipment.length) { %>
              <tr><td colspan="5" style="text-align:center;color:var(--color-ink-soft);padding:32px;">Chưa có thiết bị nào.</td></tr>
            <% } %>
            <% equipment.forEach(e => { %>
            <tr>
              <td><strong><%= e.name %></strong><% if(e.notes){ %><br><span style="font-size:0.8rem;color:var(--color-ink-soft);"><%= e.notes %></span><% } %></td>
              <td><span class="badge"><%= {reformer:'Reformer',cadillac:'Cadillac',chair:'Chair',barrel:'Barrel',tower:'Tower',other:'Khác'}[e.type]||e.type %></span></td>
              <td style="font-family:var(--font-mono);font-size:0.85rem;"><%= e.serial_number || '—' %></td>
              <td>
                <% const statusMap = {active:['Hoạt động','#d8f3dc','#1b5e34','#74c693'],maintenance:['Bảo trì','#fff3cd','#7c4700','#f0d06b'],retired:['Ngưng','#fbeae8','#c0392b','#f0b8b4']}; %>
                <% const [sLabel,sBg,sColor,sBorder] = statusMap[e.status]||statusMap.active; %>
                <span class="badge" style="background:<%= sBg %>;color:<%= sColor %>;border-color:<%= sBorder %>"><%= sLabel %></span>
              </td>
              <td>
                <div style="display:flex;gap:6px;">
                  <button class="btn-icon" title="Sửa" onclick="openEditModal(<%= JSON.stringify(e) %>)"><i class="ti ti-edit"></i></button>
                  <form method="POST" action="/equipment/<%= e.id %>/delete" onsubmit="return confirm('Xóa thiết bị này?')">
                    <button class="btn-icon btn-danger" type="submit"><i class="ti ti-trash"></i></button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Lịch bảo trì -->
    <div class="card">
      <div class="card-header"><span class="card-title"><i class="ti ti-tool"></i> Lịch bảo trì</span></div>
      <div style="overflow-x:auto;">
        <table class="table">
          <thead><tr><th>Thiết bị</th><th>Loại bảo trì</th><th>Ngày dự kiến</th><th>Ngày hoàn thành</th><th>Trạng thái</th><th></th></tr></thead>
          <tbody>
            <% if (!logs.length) { %>
              <tr><td colspan="6" style="text-align:center;color:var(--color-ink-soft);padding:32px;">Chưa có lịch bảo trì nào.</td></tr>
            <% } %>
            <% logs.forEach(l => { %>
            <tr>
              <td><strong><%= l.equipment_name %></strong></td>
              <td style="font-size:0.88rem;"><%= l.type %></td>
              <td><%= new Date(l.scheduled_date).toLocaleDateString('vi-VN') %></td>
              <td><%= l.completed_date ? new Date(l.completed_date).toLocaleDateString('vi-VN') : '—' %></td>
              <td>
                <% const logMap = {scheduled:['Đã lên lịch','#d1eaff','#1a4f7a','#93c8f2'],completed:['Hoàn thành','#d8f3dc','#1b5e34','#74c693'],overdue:['Quá hạn','#fbeae8','#c0392b','#f0b8b4']}; %>
                <% const [lLabel,lBg,lColor,lBorder] = logMap[l.status]||logMap.scheduled; %>
                <span class="badge" style="background:<%= lBg %>;color:<%= lColor %>;border-color:<%= lBorder %>"><%= lLabel %></span>
              </td>
              <td>
                <div style="display:flex;gap:6px;">
                  <% if (l.status !== 'completed') { %>
                  <form method="POST" action="/equipment/maintenance/<%= l.id %>/complete">
                    <button class="btn-icon" title="Đánh dấu hoàn thành" style="color:var(--color-moss-dark);"><i class="ti ti-check"></i></button>
                  </form>
                  <% } %>
                  <form method="POST" action="/equipment/maintenance/<%= l.id %>/delete" onsubmit="return confirm('Xóa lịch này?')">
                    <button class="btn-icon btn-danger" type="submit"><i class="ti ti-trash"></i></button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

  </div>

  <div style="display:flex;flex-direction:column;gap:20px;">

    <!-- Thêm thiết bị -->
    <div class="card">
      <div class="card-header"><span class="card-title"><i class="ti ti-plus"></i> Thêm thiết bị</span></div>
      <div class="card-body">
        <form method="POST" action="/equipment/create">
          <div class="form-group">
            <label>Tên thiết bị <span class="req">*</span></label>
            <input type="text" name="name" placeholder="Reformer #4" required />
          </div>
          <div class="form-group" style="margin-top:12px;">
            <label>Loại</label>
            <select name="type">
              <option value="reformer">Reformer</option>
              <option value="cadillac">Cadillac</option>
              <option value="chair">Wunda Chair</option>
              <option value="barrel">Barrel / Spine Corrector</option>
              <option value="tower">Tower</option>
              <option value="other">Khác</option>
            </select>
          </div>
          <div class="form-group" style="margin-top:12px;">
            <label>Số hiệu</label>
            <input type="text" name="serial_number" placeholder="RF-004" />
          </div>
          <div class="form-group" style="margin-top:12px;">
            <label>Trạng thái</label>
            <select name="status">
              <option value="active">Hoạt động</option>
              <option value="maintenance">Đang bảo trì</option>
              <option value="retired">Ngưng hoạt động</option>
            </select>
          </div>
          <div class="form-group" style="margin-top:12px;">
            <label>Ghi chú</label>
            <input type="text" name="notes" placeholder="Ghi chú..." />
          </div>
          <button class="btn btn-primary" type="submit" style="margin-top:16px;width:100%;"><i class="ti ti-plus"></i> Thêm thiết bị</button>
        </form>
      </div>
    </div>

    <!-- Lên lịch bảo trì -->
    <div class="card">
      <div class="card-header"><span class="card-title"><i class="ti ti-calendar-plus"></i> Lên lịch bảo trì</span></div>
      <div class="card-body">
        <form method="POST" action="/equipment/maintenance/create">
          <div class="form-group">
            <label>Thiết bị <span class="req">*</span></label>
            <select name="equipment_id" required>
              <option value="">-- Chọn thiết bị --</option>
              <% equipment.forEach(e => { %>
                <option value="<%= e.id %>"><%= e.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group" style="margin-top:12px;">
            <label>Ngày bảo trì <span class="req">*</span></label>
            <input type="date" name="scheduled_date" required />
          </div>
          <div class="form-group" style="margin-top:12px;">
            <label>Loại bảo trì</label>
            <input type="text" name="type" placeholder="Bảo trì định kỳ / Sửa chữa..." value="Bảo trì định kỳ" />
          </div>
          <div class="form-group" style="margin-top:12px;">
            <label>Ghi chú</label>
            <input type="text" name="notes" placeholder="Mô tả công việc..." />
          </div>
          <button class="btn btn-primary" type="submit" style="margin-top:16px;width:100%;"><i class="ti ti-calendar-plus"></i> Thêm lịch</button>
        </form>
      </div>
    </div>

  </div>
</div>

<!-- Modal sửa thiết bị -->
<div id="edit-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:12px;padding:28px;width:400px;max-width:90vw;">
    <h3 style="margin:0 0 16px;font-size:1rem;">Cập nhật thiết bị</h3>
    <form method="POST" id="edit-form">
      <input type="hidden" name="_method" value="update" />
      <div class="form-group"><label>Tên</label><input type="text" name="name" id="edit-name" required /></div>
      <div class="form-group" style="margin-top:10px;"><label>Loại</label>
        <select name="type" id="edit-type">
          <option value="reformer">Reformer</option><option value="cadillac">Cadillac</option>
          <option value="chair">Wunda Chair</option><option value="barrel">Barrel</option>
          <option value="tower">Tower</option><option value="other">Khác</option>
        </select>
      </div>
      <div class="form-group" style="margin-top:10px;"><label>Số hiệu</label><input type="text" name="serial_number" id="edit-serial" /></div>
      <div class="form-group" style="margin-top:10px;"><label>Trạng thái</label>
        <select name="status" id="edit-status">
          <option value="active">Hoạt động</option><option value="maintenance">Bảo trì</option><option value="retired">Ngưng</option>
        </select>
      </div>
      <div class="form-group" style="margin-top:10px;"><label>Ghi chú</label><input type="text" name="notes" id="edit-notes" /></div>
      <div style="display:flex;gap:10px;margin-top:18px;">
        <button class="btn btn-primary" type="submit">Lưu</button>
        <button class="btn btn-secondary" type="button" onclick="closeEditModal()">Hủy</button>
      </div>
    </form>
  </div>
</div>

<script>
function filterEquipment(q) {
  var rows = document.querySelectorAll('#eq-tbody tr');
  var term = q.trim().toLowerCase();
  var visible = 0;
  rows.forEach(function(row) {
    var text = row.textContent.toLowerCase();
    var show = !term || text.indexOf(term) !== -1;
    row.style.display = show ? '' : 'none';
    if (show) visible++;
  });
  document.getElementById('eq-count').textContent = visible + ' thiết bị';
}

function openEditModal(eq) {
  document.getElementById('edit-name').value = eq.name;
  document.getElementById('edit-type').value = eq.type;
  document.getElementById('edit-serial').value = eq.serial_number || '';
  document.getElementById('edit-status').value = eq.status;
  document.getElementById('edit-notes').value = eq.notes || '';
  document.getElementById('edit-form').action = '/equipment/' + eq.id + '/update';
  var m = document.getElementById('edit-modal');
  m.style.display = 'flex';
}
function closeEditModal() { document.getElementById('edit-modal').style.display = 'none'; }
document.getElementById('edit-modal').addEventListener('click', function(e){ if(e.target===this) closeEditModal(); });
</script>

<%- include('partials/footer') %>
