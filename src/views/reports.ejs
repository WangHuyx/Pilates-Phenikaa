<%- include('partials/header') %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="page-head">
  <div>
    <p class="eyebrow">Quản lý</p>
    <h1 class="page-title">Báo cáo & Thống kê</h1>
    <p class="lede">Tổng quan hoạt động phòng tập</p>
  </div>
</div>

<div class="stats-grid mb-4">
  <div class="stat-card">
    <p class="stat-card-label">Tổng hội viên</p>
    <p class="stat-card-value"><%= memberStats.members %></p>
    <div class="stat-card-icon stat-icon-green"><i class="ti ti-users"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Lớp học</p>
    <p class="stat-card-value"><%= classStats.total %></p>
    <div class="stat-card-icon stat-icon-blue"><i class="ti ti-calendar"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Gói đang hoạt động</p>
    <p class="stat-card-value"><%= activePackages %></p>
    <div class="stat-card-icon stat-icon-amber"><i class="ti ti-package"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Tổng doanh thu</p>
    <p class="stat-card-value"><%= Number(revenueAll).toLocaleString('vi-VN') %>đ</p>
    <div class="stat-card-icon stat-icon-orange"><i class="ti ti-coin"></i></div>
  </div>
</div>

<div class="card mb-4">
  <div class="card-header">
    <span class="card-title"><i class="ti ti-chart-bar"></i> Biểu đồ Doanh thu 6 tháng gần nhất</span>
  </div>
  <div class="card-body">
    <% if (revenueByMonth.length === 0) { %>
      <p class="empty-state">Chưa có dữ liệu doanh thu.</p>
    <% } else { %>
      <canvas id="revenueChart" height="250"></canvas>
    <% } %>
  </div>
</div>

<div class="grid-2-cols">
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="ti ti-star"></i> Lớp học phổ biến</span>
    </div>
    <div class="table-responsive">
      <table class="table">
        <thead>
          <tr><th>Tên lớp</th><th>Huấn luyện viên</th><th>Sĩ số</th><th>Tỉ lệ</th></tr>
        </thead>
        <tbody>
          <% if (popularClasses.length === 0) { %>
            <tr><td colspan="4" class="empty-state">Chưa có lớp học.</td></tr>
          <% } %>
          <% popularClasses.forEach(c => { %>
            <tr>
              <td><strong><%= c.name %></strong></td>
              <td class="text-muted"><%= c.instructor %></td>
              <td><%= c.enrollments %> / <%= c.capacity %></td>
              <td>
                <div class="progress-wrapper">
                  <div class="progress-bar <%= (c.fill_pct||0) >= 80 ? 'bg-danger' : 'bg-moss' %>" style="width: <%= Math.min(c.fill_pct||0, 100) %>px;"></div>
                  <span><%= c.fill_pct || 0 %>%</span>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="ti ti-users"></i> Phân bổ tài khoản hệ thống</span>
    </div>
    <div class="card-body">
      <div class="role-distribution-list">
        <% const roles = [
          { label: 'Admin', count: memberStats.admins, color: '#7c4700' },
          { label: 'Nhân viên', count: memberStats.staff, color: '#1a4f7a' },
          { label: 'Huấn luyện viên', count: memberStats.trainers, color: '#1b5e34' },
          { label: 'Hội viên', count: memberStats.members, color: 'var(--color-moss)' },
        ]; %>
        
        <% roles.forEach(r => { %>
          <div class="role-item">
            <div class="role-label"><%= r.label %></div>
            <div class="role-track">
              <div class="role-fill" style="background:<%= r.color %>; width: <%= memberStats.total > 0 ? Math.round(r.count/memberStats.total*100) : 0 %>%;"></div>
            </div>
            <div class="role-count"><%= r.count %></div>
          </div>
        <% }) %>
        
        <div class="role-summary-item border-top mt-2 pt-3">
          <span>Tổng cộng</span>
          <strong><%= memberStats.total %> tài khoản</strong>
        </div>
        <div class="role-summary-item">
          <span>Nhân sự đang hoạt động</span>
          <strong><%= staffStats.active %> / <%= staffStats.total %></strong>
        </div>
        <div class="role-summary-item">
          <span>Tổng lượt đăng ký lớp</span>
          <strong><%= classStats.total_enrollments %></strong>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    // Lấy dữ liệu từ Server EJS nạp vào Client JS
    const revenueData = <%- JSON.stringify(revenueByMonth) %>;
    
    if(revenueData && revenueData.length > 0) {
      const ctx = document.getElementById('revenueChart').getContext('2d');
      const labels = revenueData.map(item => item.month);
      const data = revenueData.map(item => item.revenue);

      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            label: 'Doanh thu (VNĐ)',
            data: data,
            backgroundColor: 'rgba(76, 175, 80, 0.6)', // var(--color-moss) opacity
            borderColor: 'rgba(76, 175, 80, 1)',
            borderWidth: 1,
            borderRadius: 4
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: function(context) {
                  let value = context.raw || 0;
                  return value.toLocaleString('vi-VN') + ' đ';
                }
              }
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              ticks: {
                callback: function(value) {
                  if (value >= 1000000) return (value / 1000000) + ' Tr';
                  if (value >= 1000) return (value / 1000) + ' k';
                  return value;
                }
              }
            }
          }
        }
      });
    }
  });
</script>

<%- include('partials/footer') %>