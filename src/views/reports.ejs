<%- include('partials/header') %>

<div class="page-head">
  <div>
    <p class="eyebrow">Quản lý</p>
    <h1 class="page-title">Báo cáo & Thống kê</h1>
    <p class="lede">Tổng quan hoạt động phòng tập</p>
  </div>
  <div style="display:flex;gap:10px;">
    <a href="/reports/export/excel" class="btn btn-secondary"><i class="ti ti-file-spreadsheet"></i> Xuất Excel</a>
    <a href="/reports/export/finance" class="btn btn-secondary"><i class="ti ti-file-spreadsheet"></i> Xuất tài chính</a>
  </div>
</div>

<!-- Stats tổng quan -->
<div class="stats-grid" style="margin-bottom:20px;">
  <div class="stat-card">
    <p class="stat-card-label">Tổng hội viên</p>
    <p class="stat-card-value"><%= memberStats.members %></p>
    <div class="stat-card-icon stat-icon-green"><i class="ti ti-users"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Lớp học</p>
    <p class="stat-card-value"><%= classStats.total %></p>
    <div class="stat-card-icon stat-icon-blue"><i class="ti ti-calendar"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Gói đang hoạt động</p>
    <p class="stat-card-value"><%= activePackages %></p>
    <div class="stat-card-icon stat-icon-amber"><i class="ti ti-package"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Tổng doanh thu</p>
    <p class="stat-card-value"><%= Number(revenueAll).toLocaleString('vi-VN') %>đ</p>
    <div class="stat-card-icon stat-icon-orange"><i class="ti ti-coin"></i></div>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

  <!-- Doanh thu theo tháng -->
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="ti ti-chart-bar"></i> Doanh thu 6 tháng gần nhất</span>
    </div>
    <div style="overflow-x:auto;">
      <table class="table">
        <thead>
          <tr><th>Tháng</th><th>Doanh thu</th><th>Giao dịch</th></tr>
        </thead>
        <tbody>
          <% if (revenueByMonth.length === 0) { %>
            <tr><td colspan="3" style="text-align:center;color:var(--color-ink-soft);padding:24px;">Chưa có dữ liệu.</td></tr>
          <% } %>
          <% revenueByMonth.forEach(r => { %>
            <tr>
              <td><%= r.month %></td>
              <td style="color:var(--color-moss-dark);font-weight:600;"><%= Number(r.revenue).toLocaleString('vi-VN') %>đ</td>
              <td><%= r.count %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Check-in 7 ngày -->
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="ti ti-door-enter"></i> Check-in 7 ngày gần đây</span>
    </div>
    <div style="overflow-x:auto;">
      <table class="table">
        <thead>
          <tr><th>Ngày</th><th>Lượt vào</th></tr>
        </thead>
        <tbody>
          <% if (checkinStats.length === 0) { %>
            <tr><td colspan="2" style="text-align:center;color:var(--color-ink-soft);padding:24px;">Chưa có dữ liệu check-in.</td></tr>
          <% } %>
          <% checkinStats.forEach(d => { %>
            <tr>
              <td><%= new Date(d.day).toLocaleDateString('vi-VN') %></td>
              <td>
                <div style="display:flex;align-items:center;gap:8px;">
                  <div style="height:8px;border-radius:4px;background:var(--color-moss);width:<%= Math.min(d.count*12, 100) %>px;"></div>
                  <%= d.count %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">

  <!-- Lớp học phổ biến -->
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="ti ti-star"></i> Lớp học phổ biến</span>
    </div>
    <div style="overflow-x:auto;">
      <table class="table">
        <thead>
          <tr><th>Tên lớp</th><th>Huấn luyện viên</th><th>Đăng ký / Sức chứa</th><th>Tỉ lệ</th></tr>
        </thead>
        <tbody>
          <% if (popularClasses.length === 0) { %>
            <tr><td colspan="4" style="text-align:center;color:var(--color-ink-soft);padding:24px;">Chưa có lớp học.</td></tr>
          <% } %>
          <% popularClasses.forEach(c => { %>
            <tr>
              <td><strong><%= c.name %></strong></td>
              <td style="color:var(--color-ink-soft);font-size:0.88rem;"><%= c.instructor %></td>
              <td><%= c.enrollments %> / <%= c.capacity %></td>
              <td>
                <div style="display:flex;align-items:center;gap:8px;">
                  <div style="height:8px;border-radius:4px;background:<%= (c.fill_pct||0) >= 80 ? '#c0392b' : 'var(--color-moss)' %>;width:<%= Math.min(c.fill_pct||0, 100) %>px;"></div>
                  <%= c.fill_pct || 0 %>%
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Phân bổ người dùng -->
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="ti ti-users"></i> Phân bổ tài khoản</span>
    </div>
    <div class="card-body">
      <div style="display:flex;flex-direction:column;gap:16px;">
        <% const roles = [
          { label: 'Admin', count: memberStats.admins, color: '#7c4700', bg: '#fef3cd' },
          { label: 'Nhân viên', count: memberStats.staff, color: '#1a4f7a', bg: '#d1eaff' },
          { label: 'Huấn luyện viên', count: memberStats.trainers, color: '#1b5e34', bg: '#d8f3dc' },
          { label: 'Hội viên', count: memberStats.members, color: 'var(--color-ink-soft)', bg: 'var(--color-mint)' },
        ]; %>
        <% roles.forEach(r => { %>
          <div style="display:flex;align-items:center;gap:12px;">
            <div style="min-width:120px;font-size:0.9rem;"><%= r.label %></div>
            <div style="flex:1;height:12px;border-radius:6px;background:var(--color-rail);overflow:hidden;">
              <div style="height:100%;border-radius:6px;background:<%= r.color %>;width:<%= memberStats.total > 0 ? Math.round(r.count/memberStats.total*100) : 0 %>%;transition:width 0.3s;"></div>
            </div>
            <div style="min-width:32px;text-align:right;font-weight:600;font-size:0.9rem;"><%= r.count %></div>
          </div>
        <% }) %>
        <div style="margin-top:8px;padding-top:12px;border-top:1px solid var(--color-rail);display:flex;justify-content:space-between;font-size:0.88rem;color:var(--color-ink-soft);">
          <span>Tổng cộng</span>
          <strong style="color:var(--color-ink);"><%= memberStats.total %> tài khoản</strong>
        </div>
        <div style="display:flex;justify-content:space-between;font-size:0.88rem;color:var(--color-ink-soft);">
          <span>Nhân sự đang hoạt động</span>
          <strong style="color:var(--color-ink);"><%= staffStats.active %> / <%= staffStats.total %></strong>
        </div>
        <div style="display:flex;justify-content:space-between;font-size:0.88rem;color:var(--color-ink-soft);">
          <span>Tổng lượt đăng ký lớp</span>
          <strong style="color:var(--color-ink);"><%= classStats.total_enrollments %></strong>
        </div>
      </div>
    </div>
  </div>

</div>

<%- include('partials/footer') %>
