<%- include('../partials/header', { title, user }) %>

<div class="page-head">
  <div>
    <p class="eyebrow">Lịch học</p>
    <h1>Chọn lớp học của bạn</h1>
    <p class="lede">Đăng ký ngay bên dưới — cập nhật theo thời gian thực.</p>
  </div>
  <div style="display:flex; gap:8px; align-items:center;">
    <div class="view-toggle" role="tablist" aria-label="Chế độ xem lịch học">
      <button type="button" class="view-toggle-btn active" data-view="calendar" role="tab" aria-selected="true"><i class="ti ti-calendar-week"></i> Lịch tuần</button>
      <button type="button" class="view-toggle-btn" data-view="list" role="tab" aria-selected="false"><i class="ti ti-list"></i> Danh sách</button>
    </div>
   
    <% if (user.role === 'admin' || user.role === 'staff') { %>
    <a href="/classes/manage" class="btn btn-secondary"><i class="ti ti-settings"></i> Quản lý lớp học</a>
    <% } %>
  </div>
</div>

<% if (message) { %>
  <div class="alert alert-info"><i class="ti ti-info-circle" style="flex-shrink:0"></i><span><%= message %></span></div>
<% } %>

<% if (classes.length === 0) { %>
  <div class="empty-state">
    <h1>Chưa có lớp học nào</h1>
    <p>Hiện tại chưa có lớp học nào được lên lịch. Vui lòng quay lại sau.</p>
  </div>
<% } else { %>

  <div id="calendar-view">
    <div class="cal-legend">
      <span class="cal-legend-item"><i class="cal-dot" style="background:var(--cal-basic)"></i>Cơ bản</span>
      <span class="cal-legend-item"><i class="cal-dot" style="background:var(--cal-intermediate)"></i>Trung cấp</span>
      <span class="cal-legend-item"><i class="cal-dot" style="background:var(--cal-advanced)"></i>Nâng cao</span>
      <span class="cal-legend-item"><i class="cal-dot" style="background:var(--cal-all)"></i>Mọi cấp độ</span>
    </div>

    <div class="cal-wrap">
      <div class="cal-header" id="cal-header"></div>
      <div class="cal-body" id="cal-body">
        <div class="cal-hours" id="cal-hours"></div>
        <div class="cal-grid-lines" id="cal-grid-lines"></div>
        <div class="cal-now-line" id="cal-now-line" style="display:none;"><span></span></div>
        <div class="cal-events" id="cal-events"></div>
      </div>
    </div>

    <div id="cal-unscheduled" class="cal-unscheduled" style="display:none;">
      <p class="cal-unscheduled-title"><i class="ti ti-alert-triangle"></i> Không xác định được lịch của các lớp sau — kiểm tra lại dữ liệu:</p>
      <ul id="cal-unscheduled-list"></ul>
    </div>
  </div>

  <div id="list-view" class="class-grid" style="display:none;">
    <% classes.forEach(function (classItem) { %>
      <%- include('../partials/class-card', { classItem, user, showRegister: true, hasActiveVip }) %>
    <% }); %>
  </div>

  <div id="cal-popover-root"></div>

<% } %>

<%- include('../partials/footer') %>

<% if (classes.length > 0) { %>
<script id="classes-raw-data" type="application/json"><%- JSON.stringify(classes) %></script>
<script>
(function () {
  var CSRF_TOKEN = <%- typeof csrfToken !== 'undefined' ? JSON.stringify(csrfToken) : 'null' %>;
  var CURRENT_USER_ID = <%- (user && (user.id || user._id)) ? JSON.stringify(user.id || user._id) : 'null' %>;
  var USER_ROLE = '<%- user ? user.role : "" %>'; // Thêm lấy Role để xét hiển thị Admin View
  var HAS_ACTIVE_VIP = <%- typeof hasActiveVip !== 'undefined' && hasActiveVip ? 'true' : 'false' %>; // Hội viên đang có gói VIP hiệu lực?

  var HOUR_H = 56;
  var DAY_LABELS = ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN'];
  var DAY_ALIASES = {
    mon: 0, monday: 0, t2: 0, 'thứ 2': 0, 'thu 2': 0, 'thứ hai': 0, 'thu hai': 0,
    tue: 1, tuesday: 1, t3: 1, 'thứ 3': 1, 'thu 3': 1, 'thứ ba': 1, 'thu ba': 1,
    wed: 2, wednesday: 2, t4: 2, 'thứ 4': 2, 'thu 4': 2, 'thứ tư': 2, 'thu tu': 2,
    thu: 3, thursday: 3, t5: 3, 'thứ 5': 3, 'thu 5': 3, 'thứ năm': 3, 'thu nam': 3,
    fri: 4, friday: 4, t6: 4, 'thứ 6': 4, 'thu 6': 4, 'thứ sáu': 4, 'thu sau': 4,
    sat: 5, saturday: 5, t7: 5, 'thứ 7': 5, 'thu 7': 5, 'thứ bảy': 5, 'thu bay': 5,
    sun: 6, sunday: 6, cn: 6, 'chủ nhật': 6, 'chu nhat': 6
  };
  var LEVEL_META = {
    basic: { label: 'Cơ bản', varName: '--cal-basic' },
    intermediate: { label: 'Trung cấp', varName: '--cal-intermediate' },
    advanced: { label: 'Nâng cao', varName: '--cal-advanced' },
    all: { label: 'Mọi cấp độ', varName: '--cal-all' }
  };

  function dayIndexOf(rawDay) {
    if (typeof rawDay === 'number') return ((rawDay % 7) + 7) % 7 === 0 ? 6 : rawDay - 1;
    var key = String(rawDay || '').trim().toLowerCase();
    return DAY_ALIASES.hasOwnProperty(key) ? DAY_ALIASES[key] : null;
  }

  function toMinutes(t) {
    var parts = String(t || '0:0').split(':');
    return (parseInt(parts[0], 10) || 0) * 60 + (parseInt(parts[1], 10) || 0);
  }

  var LEVEL_MAP = { 'Beginner': 'basic', 'Intermediate': 'intermediate', 'Advanced': 'advanced' };
  function normalizeLevel(classItem) {
    return LEVEL_MAP[classItem.level] || 'all';
  }
  // Đã cập nhật để map thêm thông tin Trạng thái và Danh sách học viên từ backend
  function normalizeClass(classItem) {
    return {
      id: classItem.id || classItem._id,
      name: classItem.name || classItem.title || 'Lớp học',
      levelKey: normalizeLevel(classItem),
      instructor: classItem.instructor || classItem.trainer || '',
      capacity: classItem.capacity,
      price: Number(classItem.price) || 0,
      registeredCount: (classItem.enrolledUserIds || []).length,
      isFull: (classItem.enrolledUserIds || []).length >= classItem.capacity,
      isRegistered: !!(CURRENT_USER_ID && (classItem.enrolledUserIds || []).indexOf(CURRENT_USER_ID) > -1),
      sessions: getSessions(classItem),
      
      // 2 trường mới phục vụ logic Database mới:
      enrollmentStatus: classItem.enrollmentStatus || null,
      enrolledUsers: classItem.enrolledUsers || [] 
    };
  }

  function getSessions(classItem) {
    var sessions = [];
    if (!classItem.day || !classItem.time) return sessions;
    var dayParts = String(classItem.day).split(/&|,|;|\//).map(function (s) { return s.trim(); });
    var timeParts = String(classItem.time).split('-').map(function (s) { return s.trim(); });
    if (timeParts.length !== 2) return sessions;
    dayParts.forEach(function (day) {
      var d = dayIndexOf(day);
      if (d !== null) sessions.push({ dayIndex: d, start: timeParts[0], end: timeParts[1] });
    });
    return sessions;
  }

  var rawClasses = JSON.parse(document.getElementById('classes-raw-data').textContent || '[]');
  var classes = rawClasses.map(normalizeClass);

  var calHeader = document.getElementById('cal-header');
  var calHours = document.getElementById('cal-hours');
  var calGridLines = document.getElementById('cal-grid-lines');
  var calEvents = document.getElementById('cal-events');
  var calNowLine = document.getElementById('cal-now-line');
  var unscheduledBox = document.getElementById('cal-unscheduled');
  var unscheduledList = document.getElementById('cal-unscheduled-list');
  var calBody = document.getElementById('cal-body');
  
  // Ép calBody có thể cuộn ngang để phục vụ Zoom
  calBody.style.overflowX = 'auto';

  // --- THÊM LOGIC ZOOM CHIỀU NGANG ---
  var CAL_WIDTH_PCT = 100; // Mặc định 100% chiều rộng
  function updateZoom() {
    var w = CAL_WIDTH_PCT + '%';
    calHeader.style.minWidth = w;
    calGridLines.style.minWidth = w;
    calEvents.style.minWidth = w;
    if (calNowLine) calNowLine.style.minWidth = w;
  }

  var btnZoomIn = document.getElementById('btn-zoom-in');
  var btnZoomOut = document.getElementById('btn-zoom-out');
  if (btnZoomIn) {
    btnZoomIn.addEventListener('click', function() {
      if (CAL_WIDTH_PCT < 400) { CAL_WIDTH_PCT += 50; updateZoom(); } // Zoom tối đa 400%
    });
  }
  if (btnZoomOut) {
    btnZoomOut.addEventListener('click', function() {
      if (CAL_WIDTH_PCT > 100) { CAL_WIDTH_PCT -= 50; updateZoom(); } // Thu nhỏ tối đa về gốc 100%
    });
  }
  // ------------------------------------

  var today = new Date();
  var todayIndex = (today.getDay() + 6) % 7;
  var monday = new Date(today);
  monday.setDate(today.getDate() - todayIndex);

  var headerHtml = '<div class="cal-corner"></div>';
  for (var i = 0; i < 7; i++) {
    var d = new Date(monday);
    d.setDate(monday.getDate() + i);
    var isToday = i === todayIndex;
    headerHtml += '<div class="cal-day-head' + (isToday ? ' is-today' : '') + '">' +
      '<span class="cal-day-name">' + DAY_LABELS[i] + '</span>' +
      '<span class="cal-day-num">' + d.getDate() + '/' + (d.getMonth() + 1) + '</span></div>';
  }
  calHeader.innerHTML = headerHtml;

  var hoursHtml = '';
  var linesHtml = '';
  for (var h = 0; h < 24; h++) {
    hoursHtml += '<div class="cal-hour-label" style="top:' + (h * HOUR_H - 7) + 'px">' + (h < 10 ? '0' + h : h) + ':00</div>';
    linesHtml += '<div class="cal-hline" style="top:' + (h * HOUR_H) + 'px"></div>';
  }
  calHours.innerHTML = hoursHtml;
  calGridLines.innerHTML = linesHtml;
  calGridLines.style.height = (24 * HOUR_H) + 'px';
  calEvents.style.height = (24 * HOUR_H) + 'px';
  calHours.style.height = (24 * HOUR_H) + 'px';

  var unscheduledItems = [];
  var eventsHtml = '';
  var allSessions = [];

  classes.forEach(function (c) {
    if (!c.sessions.length) {
      unscheduledItems.push(c.name);
      return;
    }
    c.sessions.forEach(function (s) {
      allSessions.push({
        classItem: c, dayIndex: s.dayIndex, startMin: toMinutes(s.start), endMin: toMinutes(s.end), startStr: s.start, endStr: s.end
      });
    });
  });

  for (var day = 0; day < 7; day++) {
    var daySessions = allSessions.filter(function(s) { return s.dayIndex === day; });
    daySessions.sort(function(a, b) { return a.startMin - b.startMin; });
    var columns = []; 
    
    daySessions.forEach(function(session) {
      var placed = false;
      for (var i = 0; i < columns.length; i++) {
        if (columns[i] <= session.startMin) { 
          columns[i] = session.endMin; session.colIndex = i; placed = true; break;
        }
      }
      if (!placed) { session.colIndex = columns.length; columns.push(session.endMin); }
    });

    var maxCols = columns.length > 0 ? columns.length : 1;

    daySessions.forEach(function(session) {
      var top = (session.startMin / 60) * HOUR_H;
      var height = Math.max((session.endMin - session.startMin) / 60 * HOUR_H, 22);
      var baseLeftPercent = session.dayIndex * (100 / 7);
      var widthPerColPercent = (100 / 7) / maxCols;
      var leftPercent = baseLeftPercent + (session.colIndex * widthPerColPercent);

      var left = 'calc(' + leftPercent + '% + 1px)';
      var width = 'calc(' + widthPerColPercent + '% - 1px)';

      eventsHtml += '<div class="cal-event level-' + session.classItem.levelKey + '" ' +
        'style="top:' + top + 'px;height:' + height + 'px;left:' + left + ';width:' + width + ';" ' +
        'data-class-id="' + session.classItem.id + '" tabindex="0" role="button" ' +
        'aria-label="' + session.classItem.name + ', ' + session.startStr + ' đến ' + session.endStr + '">' +
        '<span class="cal-event-name">' + session.classItem.name + '</span>' +
        '<span class="cal-event-time">' + session.startStr + ' - ' + session.endStr + '</span></div>';
    });
  }

  calEvents.innerHTML = eventsHtml;

  if (unscheduledItems.length) {
    unscheduledBox.style.display = '';
    unscheduledList.innerHTML = unscheduledItems.map(function (n) { return '<li>' + n + '</li>'; }).join('');
  }

  var nowMinutes = today.getHours() * 60 + today.getMinutes();
  if (todayIndex >= 0) {
    calNowLine.style.display = '';
    calNowLine.style.top = (nowMinutes / 60 * HOUR_H) + 'px';
    calNowLine.style.left = 'calc(' + todayIndex + ' * (100% / 7))';
    calNowLine.style.width = 'calc(100% / 7)';
  }

  calBody.scrollTop = Math.max(0, 6 * HOUR_H - 40);

  var popoverRoot = document.getElementById('cal-popover-root');

  function closePopover() { popoverRoot.innerHTML = ''; }

  // ĐÃ CẬP NHẬT: Xử lý nút bấm theo Trạng thái & View Admin
  function openPopover(classId) {
    var c = classes.filter(function (x) { return String(x.id) === String(classId); })[0];
    if (!c) return;
    var meta = LEVEL_META[c.levelKey];
    var seatsText = c.capacity != null ? (c.registeredCount + '/' + c.capacity + ' chỗ') : '';

    var feeText = HAS_ACTIVE_VIP
      ? '<span style="color:#15803d">Miễn phí — đang dùng gói VIP</span>'
      : (c.price > 0
          ? 'Vé lượt: <strong>' + c.price.toLocaleString('vi-VN') + 'đ</strong> (chưa có gói VIP)'
          : '<span style="color:#15803d">Miễn phí</span>');

    var actionBtn = '';
    var feeHtml = '';
    if (c.enrollmentStatus === 'pending') {
      actionBtn = '<button type="button" class="btn btn-warning" disabled style="opacity:0.9;cursor:not-allowed">⏳ Đang chờ duyệt</button>';
    } else if (c.enrollmentStatus === 'approved' || c.isRegistered) {
      actionBtn = '<button type="button" class="btn btn-success" disabled style="opacity:0.9;cursor:not-allowed">✓ Đã đặt chỗ</button>';
    } else if (c.isFull) {
      actionBtn = '<button type="button" class="btn btn-secondary" disabled style="opacity:0.6;cursor:not-allowed">Hết chỗ</button>';
    } else {
      feeHtml = '<p class="cal-popover-meta"><i class="ti ti-receipt"></i> ' + feeText + '</p>';
      actionBtn = '<form method="POST" action="/classes/' + c.id + '/register">' +
        (CSRF_TOKEN ? '<input type="hidden" name="_csrf" value="' + CSRF_TOKEN + '">' : '') +
        '<button type="submit" class="btn btn-primary">Đặt chỗ ngay</button></form>';
    }

    var adminViewHtml = '';
    if (USER_ROLE === 'admin' || USER_ROLE === 'staff') {
      var members = c.enrolledUsers || [];
      adminViewHtml = '<div style="margin-top:15px; border-top:1px solid #eee; padding-top:10px;">' +
                      '<h4 style="font-size:0.9rem; color:#666; margin-bottom:8px;">Học viên ghi danh (' + members.length + '):</h4>' +
                      '<ul style="list-style:none; padding:0; margin:0; max-height:150px; overflow-y:auto; font-size:0.85rem;">';
      if(members.length === 0) adminViewHtml += '<li style="color:#999;">Chưa có ai</li>';
      members.forEach(function(m) {
         var typeText = m.booking_type === 1 ? 'Vé tháng' : 'Mua lẻ';
         var statusText = m.status === 'approved' ? '✓' : (m.status === 'pending' ? '⏳' : '✕');
         adminViewHtml += '<li style="padding:4px 0; border-bottom:1px dashed #f0f0f0; display:flex; justify-content:space-between;">' +
                          '<span>👤 ' + m.name + '</span>' + 
                          '<span><span style="color:#15803d">[' + typeText + ']</span> <span style="color:#d97706">' + statusText + '</span></span></li>';
      });
      adminViewHtml += '</ul></div>';
    }

    popoverRoot.innerHTML =
      '<div class="cal-popover-overlay" id="cal-popover-overlay">' +
      '<div class="cal-popover" role="dialog" aria-modal="true">' +
      '<button type="button" class="cal-popover-close" aria-label="Đóng"><i class="ti ti-x"></i></button>' +
      '<span class="cal-badge level-' + c.levelKey + '">' + meta.label + '</span>' +
      '<h3 class="cal-popover-title">' + c.name + '</h3>' +
      '<p class="cal-popover-meta"><i class="ti ti-user"></i> HLV ' + (c.instructor || 'Tự tập') + '</p>' +
      (seatsText ? '<p class="cal-popover-meta"><i class="ti ti-users"></i> ' + seatsText + '</p>' : '') +
      feeHtml +
      '<div class="cal-popover-action">' + actionBtn + '</div>' +
      adminViewHtml +
      '</div></div>';

    document.getElementById('cal-popover-overlay').addEventListener('click', function (e) {
      if (e.target.id === 'cal-popover-overlay') closePopover();
    });
    popoverRoot.querySelector('.cal-popover-close').addEventListener('click', closePopover);
  }

  calEvents.addEventListener('click', function (e) {
    var el = e.target.closest('.cal-event');
    if (el) openPopover(el.getAttribute('data-class-id'));
  });
  calEvents.addEventListener('keydown', function (e) {
    if (e.key === 'Enter' || e.key === ' ') {
      var el = e.target.closest('.cal-event');
      if (el) { e.preventDefault(); openPopover(el.getAttribute('data-class-id')); }
    }
  });

  var toggleBtns = document.querySelectorAll('.view-toggle-btn');
  var calendarView = document.getElementById('calendar-view');
  var listView = document.getElementById('list-view');
  toggleBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      // Bỏ qua nếu bấm vào nút zoom
      if (btn.id === 'btn-zoom-in' || btn.id === 'btn-zoom-out') return;
      
      toggleBtns.forEach(function (b) { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      var isCalendar = btn.getAttribute('data-view') === 'calendar';
      calendarView.style.display = isCalendar ? '' : 'none';
      listView.style.display = isCalendar ? 'none' : '';
    });
  });
})();
</script>
<% } %>