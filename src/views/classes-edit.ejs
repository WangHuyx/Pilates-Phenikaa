<%- include('partials/header') %>

<div class="page-head">
  <div>
    <p class="eyebrow">Lớp học</p>
    <h1 class="page-title">Sửa lớp học</h1>
  </div>
  <a href="/classes/manage" class="btn btn-secondary"><i class="ti ti-arrow-left"></i> Quay lại</a>
</div>

<% if (error) { %><div class="alert alert-error"><i class="ti ti-alert-circle"></i> <%= error %></div><% } %>

<div style="max-width:560px;">
  <div class="card">
    <div class="card-header"><span class="card-title"><i class="ti ti-edit"></i> Thông tin lớp học</span></div>
    <div class="card-body">
      <form method="POST" action="/classes/<%= cls.id %>/update">
        <div class="form-group">
          <label>Tên lớp <span class="req">*</span></label>
          <input type="text" name="name" value="<%= cls.name %>" required />
        </div>
        <div class="form-group" style="margin-top:12px;">
          <label>Huấn luyện viên <span class="req">*</span></label>
          <input type="text" name="instructor" value="<%= cls.instructor %>" required />
        </div>
        <div class="form-group" style="margin-top:12px;">
          <label>Thứ <span class="req">*</span></label>
          <select name="day" required>
            <% ['Thứ Hai','Thứ Ba','Thứ Tư','Thứ Năm','Thứ Sáu','Thứ Bảy','Chủ Nhật'].forEach(d => { %>
              <option value="<%= d %>" <%= cls.day===d?'selected':'' %>><%= d %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group" style="margin-top:12px;">
          <label>Giờ học <span class="req">*</span></label>
          <input type="text" name="time" value="<%= cls.time %>" required />
        </div>
        <div class="form-group" style="margin-top:12px;">
          <label>Cấp độ</label>
          <select name="level">
            <% [['All levels','Mọi cấp độ'],['Beginner','Cơ bản'],['Intermediate','Trung cấp'],['Advanced','Nâng cao']].forEach(([v,l]) => { %>
              <option value="<%= v %>" <%= cls.level===v?'selected':'' %>><%= l %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group" style="margin-top:12px;">
          <label>Sĩ số tối đa</label>
          <input type="number" name="capacity" value="<%= cls.capacity %>" min="1" max="50" />
        </div>
        <div style="display:flex;gap:10px;margin-top:20px;">
          <button class="btn btn-primary" type="submit"><i class="ti ti-check"></i> Lưu thay đổi</button>
          <a href="/classes/manage" class="btn btn-secondary">Hủy</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
