<%
  const spotsTaken = classItem.enrolledUserIds.length;
  const spotsLeft = classItem.capacity - spotsTaken;
  const isFull = spotsLeft <= 0;
  const enrollmentStatus = classItem.enrollmentStatus || null;
  const isPending = enrollmentStatus === 'pending';
  const isBooked = enrollmentStatus === 'approved' || (typeof user !== 'undefined' && user && classItem.enrolledUserIds.includes(user.id) && !isPending);

  const levelToSpring = {
    'Beginner':     'spring-light',
    'Intermediate': 'spring-medium',
    'Advanced':     'spring-heavy',
  };
  const springClass = levelToSpring[classItem.level] || 'spring-all';

  const levelLabel = {
    'Beginner':     'Cơ bản',
    'Intermediate': 'Trung cấp',
    'Advanced':     'Nâng cao',
  };
  const displayLevel = levelLabel[classItem.level] || classItem.level;
%>
<article class="class-card">
  <span class="class-card-rail"></span>
  <div class="class-card-body">
    <div class="class-card-top">
      <span class="spring-tag <%= springClass %>"><%= displayLevel %></span>
      <span class="class-time"><%= classItem.day %> · <%= classItem.time %></span>
    </div>

    <h3 class="class-name"><%= classItem.name %></h3>
    <p class="class-instructor">HLV <%= classItem.instructor %></p>

    <div class="capacity-row" aria-label="<%= spotsTaken %>/<%= classItem.capacity %> chỗ đã đặt">
      <% for (let i = 0; i < classItem.capacity; i++) { %>
        <span class="capacity-dot<%= i < spotsTaken ? ' is-filled' : '' %>"></span>
      <% } %>
      <span class="capacity-label"><%= spotsTaken %>/<%= classItem.capacity %> chỗ</span>
    </div>

    <% if (classItem.price) { %>
      <p style="font-size:0.82rem;color:var(--color-ink-soft);margin:4px 0 0;">
        <% if (typeof hasActiveVip !== 'undefined' && hasActiveVip) { %>
          <span style="color:#15803d;">Miễn phí — đang dùng gói VIP</span>
        <% } else { %>
          Vé lượt: <strong><%= Number(classItem.price).toLocaleString('vi-VN') %>đ</strong>
        <% } %>
      </p>
    <% } %>

    <% if (typeof showRegister !== 'undefined' && showRegister) { %>
      <% if (isPending) { %>
        <button class="btn btn-warning" type="button" disabled style="opacity:0.9;cursor:not-allowed">⏳ Đang chờ duyệt</button>
      <% } else if (isBooked) { %>
        <button class="btn btn-secondary" type="button" disabled style="opacity:0.7;cursor:not-allowed">✓ Đã đặt chỗ</button>
      <% } else if (isFull) { %>
        <button class="btn btn-secondary" type="button" disabled style="opacity:0.6;cursor:not-allowed">Hết chỗ</button>
      <% } else { %>
        <form method="POST" action="/classes/<%= classItem.id %>/register">
          <button type="submit" class="btn btn-primary">Đặt chỗ ngay</button>
        </form>
      <% } %>
    <% } %>
  </div>
</article>
