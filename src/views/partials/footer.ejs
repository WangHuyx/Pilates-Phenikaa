  </main><%# /page-content %>
</div><%# /main-area %>
</div><%# /app-shell %>

<script>
function applySidebarState() {
  var path = window.location.pathname;
  var links = document.querySelectorAll('.sidebar-link[data-path]');
  links.forEach(function (link) {
    var lp = link.getAttribute('data-path');
    var isActive = path === lp ||
      (lp === '/employees' && path.startsWith('/employees')) ||
      (lp === '/packages'  && path.startsWith('/packages'))  ||
      (lp === '/trainers'  && path.startsWith('/trainers'))  ||
      (lp === '/accounts'  && path.startsWith('/accounts'));
    link.classList.toggle('active', isActive);
  });

  /* Nhân sự group: mở khi đang ở trang con của nó, đóng lại ở mọi trang khác */
  var shouldExpandNhanSu = path.startsWith('/employees') || path.startsWith('/trainers') ||
    path === '/payroll' || path === '/permissions';
  var grp = document.getElementById('group-nhansu');
  var chv = document.getElementById('chevron-nhansu');
  if (grp) grp.classList.toggle('expanded', shouldExpandNhanSu);
  if (chv) chv.style.transform = shouldExpandNhanSu ? 'rotate(180deg)' : '';
}

applySidebarState();
/* Trang được khôi phục từ bfcache (nút back/forward) vẫn giữ state DOM cũ — chạy lại để đồng bộ đúng trang hiện tại */
window.addEventListener('pageshow', function (e) {
  if (e.persisted) applySidebarState();
});

function toggleSidebarGroup(name) {
  var grp = document.getElementById('group-' + name);
  var chv = document.getElementById('chevron-' + name);
  if (!grp) return;
  var isOpen = grp.classList.toggle('expanded');
  if (chv) chv.style.transform = isOpen ? 'rotate(180deg)' : '';
}
</script>
</body>
</html>
