  </main><%# /page-content %>
</div><%# /main-area %>
</div><%# /app-shell %>

<script>
function applySidebarState() {
  var path = window.location.pathname;
  // Trang hồ sơ cá nhân (/accounts/<id chính mình>/edit) không được tính là
  // thuộc về "Quản lý tài khoản" — nếu không mục đó sẽ bị tô đậm nhầm mỗi khi
  // người dùng đang xem hồ sơ của chính mình.
  var ownProfilePath = <%- (typeof user !== 'undefined' && user) ? JSON.stringify('/accounts/' + user.id + '/edit') : 'null' %>;
  var links = document.querySelectorAll('.sidebar-link[data-path]');
  links.forEach(function (link) {
    var lp = link.getAttribute('data-path');
    var isActive = path === lp ||
      (lp === '/employees' && path.startsWith('/employees')) ||
      (lp === '/packages'  && path.startsWith('/packages'))  ||
      (lp === '/trainers'  && path.startsWith('/trainers'))  ||
      (lp === '/accounts'  && path.startsWith('/accounts') && path !== ownProfilePath);
    link.classList.toggle('active', isActive);
  });

  /* Mọi nhóm menu con (Nhân sự, Lớp học, ...): tự mở khi đang ở 1 trong các
     trang con của nhóm, hoặc nếu người dùng đã từng mở tay trước đó (lưu
     trong localStorage) thì vẫn giữ mở khi chuyển sang trang khác — chỉ
     đóng lại khi người dùng tự bấm đóng. Áp dụng chung cho mọi nhóm, không
     cần viết riêng từng nhóm một. */
  document.querySelectorAll('.sidebar-group-items').forEach(function (grp) {
    var name = grp.id.replace(/^group-/, '');
    var chv = document.getElementById('chevron-' + name);
    var isOnChildPage = false;
    grp.querySelectorAll('.sidebar-link[data-path]').forEach(function (link) {
      var lp = link.getAttribute('data-path');
      if (lp && (path === lp || path.startsWith(lp + '/'))) isOnChildPage = true;
    });
    var stored = localStorage.getItem('sidebar_group_' + name);
    var shouldExpand = isOnChildPage || stored === '1';
    grp.classList.toggle('expanded', shouldExpand);
    if (chv) chv.style.transform = shouldExpand ? 'rotate(180deg)' : '';
  });
}

applySidebarState();
/* Trang được khôi phục từ bfcache (nút back/forward) vẫn giữ state DOM cũ — chạy lại để đồng bộ đúng trang hiện tại */
window.addEventListener('pageshow', function (e) {
  if (e.persisted) applySidebarState();
});

function toggleSidebarGroup(name) {
  var grp = document.getElementById('group-' + name);
  var chv = document.getElementById('chevron-' + name);
  if (!grp) return;
  var isOpen = grp.classList.toggle('expanded');
  if (chv) chv.style.transform = isOpen ? 'rotate(180deg)' : '';
  localStorage.setItem('sidebar_group_' + name, isOpen ? '1' : '0');
}
</script>
</body>
</html>
