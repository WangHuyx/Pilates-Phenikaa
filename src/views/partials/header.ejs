<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> · Pilates Phenikaa</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@400;500;600&family=Libre+Caslon+Text:ital@0;1&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css" />
</head>
<body>
<div class="app-shell">

<%# ===================== SIDEBAR ===================== %>
<% if (typeof user !== 'undefined' && user) { %>
<aside class="sidebar">

  <%# Logo %>
  <div class="sidebar-logo">
    <div class="sidebar-logo-icon">🌿</div>
    <div>
      <div class="sidebar-app-name">Pilates Phenikaa</div>
      <div class="sidebar-app-sub">Quản lý phòng tập</div>
    </div>
  </div>

  <%# User info %>
  <div class="sidebar-user">
    <div class="sidebar-user-avatar">
      <%= user.fullName ? user.fullName.trim().split(' ').pop()[0].toUpperCase() : 'U' %>
    </div>
    <div style="min-width:0">
      <div class="sidebar-user-name"><%= user.fullName %></div>
      <div class="sidebar-user-role">
        <%= user.role === 'admin'   ? 'Quản trị viên'   :
            user.role === 'staff'   ? 'Nhân viên'        :
            user.role === 'trainer' ? 'Huấn luyện viên' : 'Hội viên' %>
      </div>
    </div>
  </div>

  <%# Navigation %>
  <nav class="sidebar-nav">

    <a href="/dashboard" class="sidebar-link" data-path="/dashboard">
      <i class="ti ti-layout-dashboard sidebar-link-icon"></i>
      Tổng quan
    </a>

    <%# Quyền xem/quản lý hội viên (member.view) — do trang /permissions cấu hình thật %>
    <% if (hasPermission('member.view')) { %>
    <a href="/accounts" class="sidebar-link" data-path="/accounts">
      <i class="ti ti-users sidebar-link-icon"></i>
      <%= user.role === 'admin' ? 'Quản lí tài khoản' : 'Quản lý hội viên' %>
    </a>
    <% } %>

    <%# Nhân sự (staff.view) — mục "Phân quyền" luôn chỉ dành riêng cho Admin %>
    <% if (hasPermission('staff.view')) { %>
    <button class="sidebar-link sidebar-group-toggle" onclick="toggleSidebarGroup('nhansu')">
      <i class="ti ti-briefcase sidebar-link-icon"></i>
      <span>Nhân sự</span>
      <i class="ti ti-chevron-down sidebar-link-chevron" id="chevron-nhansu"></i>
    </button>
    <div class="sidebar-group-items" id="group-nhansu">
      <a href="/employees" class="sidebar-link sidebar-sublink" data-path="/employees">
        <i class="ti ti-circle sidebar-sublink-dot"></i>
        Danh sách nhân sự
      </a>
      <a href="/trainers" class="sidebar-link sidebar-sublink" data-path="/trainers">
        <i class="ti ti-circle sidebar-sublink-dot"></i>
        Huấn luyện viên
      </a>
      <% if (user.role === 'admin') { %>
      <a href="/permissions" class="sidebar-link sidebar-sublink" data-path="/permissions">
        <i class="ti ti-circle sidebar-sublink-dot"></i>
        Phân quyền
      </a>
      <% } %>
    </div>
    <% } %>

    <%# Gói tập: member luôn thấy (để mua gói); staff chỉ thấy nếu được cấp package.view %>
    <% if (hasPermission('package.view') || user.role === 'member') { %>
    <a href="/packages" class="sidebar-link" data-path="/packages">
      <i class="ti ti-package sidebar-link-icon"></i>
      Gói tập
    </a>
    <% } %>

    <%# Lớp học (nhóm menu con: lịch học, quản lý, duyệt đặt chỗ, lớp của tôi) %>
    <button class="sidebar-link sidebar-group-toggle" onclick="toggleSidebarGroup('lophoc')">
      <i class="ti ti-calendar sidebar-link-icon"></i>
      <span>Lớp học</span>
      <i class="ti ti-chevron-down sidebar-link-chevron" id="chevron-lophoc"></i>
    </button>
    <div class="sidebar-group-items" id="group-lophoc">
      <a href="/classes" class="sidebar-link sidebar-sublink" data-path="/classes">
        <i class="ti ti-circle sidebar-sublink-dot"></i>
        Lịch học
      </a>
      <% if (hasPermission('class.view')) { %>
      <a href="/classes/manage" class="sidebar-link sidebar-sublink" data-path="/classes/manage">
        <i class="ti ti-circle sidebar-sublink-dot"></i>
        Quản lý lớp học
      </a>
      <% } %>
      <% if (user.role === 'admin') { %>
      <a href="/classes/approvals" class="sidebar-link sidebar-sublink" data-path="/classes/approvals">
        <i class="ti ti-circle sidebar-sublink-dot"></i>
        Duyệt đặt chỗ
      </a>
      <% } %>
      <% if (user.role === 'member') { %>
      <a href="/my-bookings" class="sidebar-link sidebar-sublink" data-path="/my-bookings">
        <i class="ti ti-circle sidebar-sublink-dot"></i>
        Lớp của tôi
      </a>
      <% } %>
    </div>

    <%# Tài chính (finance.view) %>
    <% if (hasPermission('finance.view')) { %>
    <a href="/finance" class="sidebar-link" data-path="/finance">
      <i class="ti ti-coin sidebar-link-icon"></i>
      Tài chính
    </a>
    <% } %>

    <%# Thiết bị (equipment.view) %>
    <% if (hasPermission('equipment.view')) { %>
    <a href="/equipment" class="sidebar-link" data-path="/equipment">
      <i class="ti ti-tool sidebar-link-icon"></i>
      Thiết bị
    </a>
    <% } %>

    <%# Báo cáo (report.view) %>
    <% if (hasPermission('report.view')) { %>
    <a href="/reports" class="sidebar-link" data-path="/reports">
      <i class="ti ti-chart-bar sidebar-link-icon"></i>
      Báo cáo
    </a>
    <% } %>

    <%# All users: hồ sơ cá nhân %>
    <div class="sidebar-divider"></div>
    <a href="/accounts/<%= user.id %>/edit" class="sidebar-link" data-path="/accounts/<%= user.id %>/edit">
      <i class="ti ti-user-circle sidebar-link-icon"></i>
      Hồ sơ cá nhân
    </a>

  </nav>

  <%# Logout %>
  <div class="sidebar-footer">
    <a href="/logout" class="sidebar-logout">
      <i class="ti ti-logout"></i>
      Đăng xuất
    </a>
  </div>

</aside>
<% } %>

<%# ===================== MAIN AREA ===================== %>
<div class="main-area">

  <%# Topbar %>
  <% if (typeof user !== 'undefined' && user) { %>
  <header class="topbar">
    <div class="topbar-left">
      <h1 class="topbar-title"><%= title %></h1>
    </div>
    <div class="topbar-right">
      <div class="topbar-search">
        <!-- <i class="ti ti-search topbar-search-icon"></i> -->
        <!-- <input type="text" placeholder="Tìm kiếm..." class="topbar-search-input" /> -->
      </div>
      <button class="topbar-notify" title="Thông báo">
        <i class="ti ti-bell"></i>
      </button>
      <div class="topbar-avatar" title="<%= user.fullName %>">
        <%= user.fullName ? user.fullName.trim().split(' ').pop()[0].toUpperCase() : 'U' %>
      </div>
    </div>
  </header>
  <% } %>

  <%# Page content — views render here %>
  <main class="page-content">
