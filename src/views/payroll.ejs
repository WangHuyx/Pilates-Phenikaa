<%- include('partials/header') %>

<div class="page-head">
  <div>
    <p class="eyebrow">Nhân sự</p>
    <h1 class="page-title">Bảng lương</h1>
    <p class="lede">Điểm danh và tính lương theo tháng</p>
  </div>
  <form method="GET" action="/payroll" style="display:flex;gap:8px;align-items:center;">
    <input type="month" name="month" value="<%= month %>" style="padding:8px 12px;border:1px solid var(--color-rail);border-radius:var(--radius-md);font-size:0.875rem;" />
    <button class="btn btn-secondary" type="submit"><i class="ti ti-search"></i> Xem</button>
  </form>
</div>

<% if (success) { %><div class="alert alert-success"><i class="ti ti-circle-check"></i> <%= success %></div><% } %>
<% if (error) { %><div class="alert alert-error"><i class="ti ti-alert-circle"></i> <%= error %></div><% } %>

<!-- Tổng kết tháng -->
<div class="stats-grid" style="margin-bottom:20px;">
  <div class="stat-card">
    <p class="stat-card-label">Tổng quỹ lương tháng</p>
    <p class="stat-card-value"><%= Number(summary.total).toLocaleString('vi-VN') %>đ</p>
    <div class="stat-card-icon stat-icon-green"><i class="ti ti-coin"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Đã thanh toán</p>
    <p class="stat-card-value"><%= Number(summary.paid).toLocaleString('vi-VN') %>đ</p>
    <div class="stat-card-icon stat-icon-blue"><i class="ti ti-check"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Số bản ghi lương</p>
    <p class="stat-card-value"><%= summary.count %></p>
    <div class="stat-card-icon stat-icon-amber"><i class="ti ti-users"></i></div>
  </div>
  <div class="stat-card">
    <p class="stat-card-label">Tháng</p>
    <p class="stat-card-value" style="font-size:1.2rem;"><%= month %></p>
    <div class="stat-card-icon stat-icon-orange"><i class="ti ti-calendar"></i></div>
  </div>
</div>

<!-- Tab: Nhân viên | Huấn luyện viên -->
<div style="display:flex;gap:4px;margin-bottom:16px;">
  <button onclick="switchTab('staff')"   id="tab-staff"   class="btn btn-primary"   style="border-radius:var(--radius-md) 0 0 var(--radius-md);">Nhân viên (<%= staffList.length %>)</button>
  <button onclick="switchTab('trainer')" id="tab-trainer" class="btn btn-secondary" style="border-radius:0 var(--radius-md) var(--radius-md) 0;">Huấn luyện viên (<%= trainerList.length %>)</button>
</div>

<!-- Nhân viên -->
<div id="section-staff">
  <div class="card">
    <div class="card-header"><span class="card-title"><i class="ti ti-briefcase"></i> Bảng lương nhân viên — <%= month %></span></div>
    <div style="overflow-x:auto;">
      <table class="table">
        <thead>
          <tr>
            <th>Nhân viên</th>
            <th>Vị trí</th>
            <th>Lương cơ bản</th>
            <th>Điểm danh</th>
            <th>Ngày vắng</th>
            <th>Thực lĩnh</th>
            <th>Trạng thái</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% if (!staffList.length) { %>
            <tr><td colspan="8" style="text-align:center;color:var(--color-ink-soft);padding:28px;">Không có nhân viên nào đang hoạt động.</td></tr>
          <% } %>
          <% staffList.forEach(s => { %>
          <tr>
            <td>
              <strong><%= s.full_name %></strong><br>
              <span style="font-size:0.78rem;color:var(--color-ink-soft);"><%= s.staff_code %></span>
            </td>
            <td style="font-size:0.88rem;"><%= s.role || '—' %></td>
            <td style="font-weight:600;"><%= Number(s.salary||0).toLocaleString('vi-VN') %>đ</td>
            <td>
              <a href="/payroll/attendance/staff/<%= s.id %>?month=<%= month %>" style="color:var(--color-moss-dark);font-weight:600;text-decoration:none;">
                <%= s.att.present %> ngày
              </a>
            </td>
            <td style="color:<%= s.att.absent>0?'#c0392b':'var(--color-ink-soft)' %>"><%= s.att.absent %></td>
            <td>
              <% if (s.pay) { %>
                <strong style="color:var(--color-moss-dark);"><%= Number(s.pay.total_salary).toLocaleString('vi-VN') %>đ</strong>
              <% } else { %>
                <span style="color:var(--color-ink-soft);font-size:0.85rem;">Chưa tính</span>
              <% } %>
            </td>
            <td>
              <% if (s.pay) { %>
                <% const sMap={draft:['Nháp','#f0f0f0','#666'],confirmed:['Xác nhận','#d1eaff','#1a4f7a'],paid:['Đã TT','#d8f3dc','#1b5e34']}; %>
                <% const [sL,sBg,sC]=sMap[s.pay.status]||sMap.draft; %>
                <span class="badge" style="background:<%= sBg %>;color:<%= sC %>;border:none;"><%= sL %></span>
              <% } else { %>—<% } %>
            </td>
            <td>
              <div style="display:flex;gap:4px;align-items:center;">
                <!-- Tính lương -->
                <button class="btn btn-sm btn-secondary" onclick="openCalcModal('staff','<%= s.id %>','<%= s.full_name %>','<%= month %>')">
                  <i class="ti ti-calculator"></i> Tính
                </button>
                <% if (s.pay) { %>
                <form method="POST" action="/payroll/<%= s.pay.id %>/status" style="display:inline">
                  <input type="hidden" name="month" value="<%= month %>">
                  <select name="status" onchange="this.form.submit()" style="padding:4px 8px;border:1px solid var(--color-rail);border-radius:var(--radius-md);font-size:0.8rem;cursor:pointer;">
                    <option value="draft"     <%= s.pay.status==='draft'?'selected':'' %>>Nháp</option>
                    <option value="confirmed" <%= s.pay.status==='confirmed'?'selected':'' %>>Xác nhận</option>
                    <option value="paid"      <%= s.pay.status==='paid'?'selected':'' %>>Đã TT</option>
                  </select>
                </form>
                <% } %>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Huấn luyện viên -->
<div id="section-trainer" style="display:none;">
  <div class="card">
    <div class="card-header"><span class="card-title"><i class="ti ti-users"></i> Bảng lương huấn luyện viên — <%= month %></span></div>
    <div style="overflow-x:auto;">
      <table class="table">
        <thead>
          <tr>
            <th>HLV</th>
            <th>Chuyên môn</th>
            <th>Lương cơ bản</th>
            <th>Điểm danh</th>
            <th>Số lớp</th>
            <th>Thực lĩnh</th>
            <th>Trạng thái</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% if (!trainerList.length) { %>
            <tr><td colspan="8" style="text-align:center;color:var(--color-ink-soft);padding:28px;">Không có HLV nào đang hoạt động.</td></tr>
          <% } %>
          <% trainerList.forEach(t => { %>
          <tr>
            <td>
              <strong><%= t.full_name %></strong><br>
              <span style="font-size:0.78rem;color:var(--color-ink-soft);"><%= t.trainer_code %></span>
            </td>
            <td style="font-size:0.88rem;"><%= t.specialization || '—' %></td>
            <td style="font-weight:600;"><%= Number(t.salary||0).toLocaleString('vi-VN') %>đ</td>
            <td>
              <a href="/payroll/attendance/trainer/<%= t.id %>?month=<%= month %>" style="color:var(--color-moss-dark);font-weight:600;text-decoration:none;">
                <%= t.att.present %> ngày
              </a>
            </td>
            <td><%= t.classes %> lớp</td>
            <td>
              <% if (t.pay) { %>
                <strong style="color:var(--color-moss-dark);"><%= Number(t.pay.total_salary).toLocaleString('vi-VN') %>đ</strong>
              <% } else { %>
                <span style="color:var(--color-ink-soft);font-size:0.85rem;">Chưa tính</span>
              <% } %>
            </td>
            <td>
              <% if (t.pay) { %>
                <% const sMap={draft:['Nháp','#f0f0f0','#666'],confirmed:['Xác nhận','#d1eaff','#1a4f7a'],paid:['Đã TT','#d8f3dc','#1b5e34']}; %>
                <% const [sL,sBg,sC]=sMap[t.pay.status]||sMap.draft; %>
                <span class="badge" style="background:<%= sBg %>;color:<%= sC %>;border:none;"><%= sL %></span>
              <% } else { %>—<% } %>
            </td>
            <td>
              <div style="display:flex;gap:4px;align-items:center;">
                <button class="btn btn-sm btn-secondary" onclick="openCalcModal('trainer','<%= t.id %>','<%= t.full_name %>','<%= month %>')">
                  <i class="ti ti-calculator"></i> Tính
                </button>
                <% if (t.pay) { %>
                <form method="POST" action="/payroll/<%= t.pay.id %>/status" style="display:inline">
                  <input type="hidden" name="month" value="<%= month %>">
                  <select name="status" onchange="this.form.submit()" style="padding:4px 8px;border:1px solid var(--color-rail);border-radius:var(--radius-md);font-size:0.8rem;cursor:pointer;">
                    <option value="draft"     <%= t.pay.status==='draft'?'selected':'' %>>Nháp</option>
                    <option value="confirmed" <%= t.pay.status==='confirmed'?'selected':'' %>>Xác nhận</option>
                    <option value="paid"      <%= t.pay.status==='paid'?'selected':'' %>>Đã TT</option>
                  </select>
                </form>
                <% } %>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Modal tính lương -->
<div id="calc-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:12px;padding:28px;width:420px;max-width:92vw;">
    <h3 style="margin:0 0 4px;font-size:1rem;">Tính lương</h3>
    <p id="calc-name" style="margin:0 0 18px;color:var(--color-ink-soft);font-size:0.88rem;"></p>
    <form method="POST" action="/payroll/calculate">
      <input type="hidden" name="employee_type" id="calc-type" />
      <input type="hidden" name="employee_ref_id" id="calc-id" />
      <input type="hidden" name="month" id="calc-month" />
      <div class="form-grid" style="gap:12px;">
        <div class="form-group">
          <label>Số ngày công quy định</label>
          <input type="number" name="working_days" value="26" min="1" max="31" />
        </div>
        <div class="form-group">
          <label>Thưởng (VNĐ)</label>
          <input type="number" name="bonus" value="0" min="0" />
        </div>
        <div class="form-group">
          <label>Khấu trừ (VNĐ)</label>
          <input type="number" name="deduction" value="0" min="0" />
        </div>
        <div class="form-group">
          <label>Ghi chú</label>
          <input type="text" name="note" placeholder="Ghi chú lương..." />
        </div>
      </div>
      <p style="font-size:0.8rem;color:var(--color-ink-soft);margin:12px 0;background:var(--color-mint);padding:10px;border-radius:var(--radius-md);">
        Công thức: <strong>Lương thực lĩnh = (Lương cơ bản ÷ Ngày công) × Ngày có mặt + Thưởng − Khấu trừ</strong>
      </p>
      <div style="display:flex;gap:10px;margin-top:8px;">
        <button class="btn btn-primary" type="submit"><i class="ti ti-calculator"></i> Tính & Lưu</button>
        <button class="btn btn-secondary" type="button" onclick="closeCalcModal()">Hủy</button>
      </div>
    </form>
  </div>
</div>

<script>
function switchTab(tab) {
  document.getElementById('section-staff').style.display   = tab==='staff'   ? '' : 'none';
  document.getElementById('section-trainer').style.display = tab==='trainer' ? '' : 'none';
  document.getElementById('tab-staff').className   = 'btn ' + (tab==='staff'   ? 'btn-primary' : 'btn-secondary');
  document.getElementById('tab-trainer').className = 'btn ' + (tab==='trainer' ? 'btn-primary' : 'btn-secondary');
  document.getElementById('tab-staff').style.borderRadius   = 'var(--radius-md) 0 0 var(--radius-md)';
  document.getElementById('tab-trainer').style.borderRadius = '0 var(--radius-md) var(--radius-md) 0';
}
function openCalcModal(type, id, name, month) {
  document.getElementById('calc-type').value  = type;
  document.getElementById('calc-id').value    = id;
  document.getElementById('calc-month').value = month;
  document.getElementById('calc-name').textContent = name + ' — ' + month;
  document.getElementById('calc-modal').style.display = 'flex';
}
function closeCalcModal() { document.getElementById('calc-modal').style.display = 'none'; }
document.getElementById('calc-modal').addEventListener('click', function(e){ if(e.target===this) closeCalcModal(); });
</script>

<%- include('partials/footer') %>
